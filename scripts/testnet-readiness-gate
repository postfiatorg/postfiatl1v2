    observability_pack_ok: ($observability[0].observability_ok == true),
    rpc_serve_ok: ($rpc_serve[0].rpc_serve_ok == true),
    rpc_serve_tamper_ok: ($rpc_serve_tamper[0].tamper_ok == true),
