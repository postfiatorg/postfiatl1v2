    and .transport_certified_batch_loop_ok == true
    and .certificate_size_metrics_ok == true
    and .final_block_height == $rounds
  )' >"$REPORT"

jq -e \
  --arg wallet_signer_mode "$WALLET_SIGNER_MODE" \
  --argjson validators "$VALIDATORS" \
  --argjson rounds "$ROUNDS" \
  '.schema == "postfiat-testnet-readiness-gate-v1"
    and .readiness_ok == true
    and .validators == $validators
    and .rounds == $rounds
    and .wallet_signer_mode == $wallet_signer_mode
    and .final_block_height == $rounds
    and .wallet_minimum_ok == true
    and .wallet_sign_transfer_ok == true
    and .wallet_test_vectors_ok == true
    and .rpc_edge_exhaustion_ok == true
    and .history_retention_ok == true
    and .history_role_policy_ok == true
    and .certificate_size_metrics_ok == true
    and .certificate_artifact_metrics.registry_root_bound == true
    and .certificate_artifact_metrics.compact_votes == true
    and .governance_replay_package_ok == true
    and .governance_genesis_bundle_ok == true
    and .certificate_artifact_metrics.votes_with_public_key_hex == 0' \
  "$REPORT" >/dev/null

if grep -R -E '"private_key_hex"' "$REPORT" "$LOG_DIR" >/dev/null; then
  echo "testnet readiness gate leaked private key material" >&2
  exit 1
fi

printf 'testnet_readiness_gate=ok validators=%s rounds=%s report=%s final_height=%s\n' \
  "$VALIDATORS" "$ROUNDS" "$REPORT" "$ROUNDS"
