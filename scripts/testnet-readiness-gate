#!/usr/bin/env bash
set -euo pipefail

VALIDATORS="${VALIDATORS:-4}"
ROUNDS="${ROUNDS:-3}"
ROOT_DIR="${ROOT_DIR:-reports/testnet-readiness-gate}"
LOG_DIR="${LOG_DIR:-$ROOT_DIR/logs}"
NODE_DIR="${NODE_DIR:-$ROOT_DIR/nodes}"
REPORT="${REPORT:-$ROOT_DIR/testnet-readiness-gate-$(date -u +%Y%m%dT%H%M%SZ).json}"
TIMEOUT_SECONDS="${TIMEOUT_SECONDS:-20}"
TRANSPORT_TIMEOUT_MS="${TRANSPORT_TIMEOUT_MS:-10000}"
PROVISION_PRIVATE_OUT_DIR="${PROVISION_PRIVATE_OUT_DIR:-$ROOT_DIR/private-key-material}"
WALLET_SIGNER_MODE="${WALLET_SIGNER_MODE:-sdk}"

require_command() {
  local command="$1"
  if ! command -v "$command" >/dev/null 2>&1; then
    echo "missing required command: $command" >&2
    exit 1
  fi
}

require_positive_integer() {
  local name="$1"
  local value="$2"
  if ! [[ "$value" =~ ^[0-9]+$ ]] || [ "$value" -lt 1 ]; then
    echo "$name must be a positive integer" >&2
    exit 2
  fi
}

write_certificate_metrics() {
  local scan_dir="$1"
  local output="$2"
  local generated_utc="$3"
  local tmp
  tmp="$(mktemp)"
  while IFS= read -r -d '' certificate_file; do
    local bytes
    bytes="$(wc -c <"$certificate_file" | tr -d ' ')"
    jq -c \
      --arg path "$certificate_file" \
      --argjson bytes "$bytes" \
      '(.certificate // {}) as $certificate
        | ($certificate.votes // []) as $votes
        | {
          path: $path,
          bytes: $bytes,
          block_height: (.block_height // null),
          certificate_id: (.certificate_id // ""),
          registry_root: ($certificate.registry_root // ""),
          vote_count: ($votes | length),
          votes_with_registry_root: (
            $votes | map(select((.registry_root // "") != "")) | length
          ),
          votes_with_public_key_hex: (
            $votes
            | map(select(has("public_key_hex") and (.public_key_hex // "") != ""))
            | length
          )
        }' "$certificate_file" >>"$tmp"
  done < <(find "$scan_dir" -type f -name 'block-certificate.json' -print0)

  jq -s \
    --arg schema "postfiat-testnet-certificate-size-metrics-v1" \
    --arg generated_utc "$generated_utc" \
    '{
      schema: $schema,
      generated_utc: $generated_utc,
      artifact_count: length,
      total_bytes: (map(.bytes) | add // 0),
      max_bytes: (map(.bytes) | max // 0),
      vote_count: (map(.vote_count) | add // 0),
      votes_with_registry_root: (map(.votes_with_registry_root) | add // 0),
      votes_with_public_key_hex: (map(.votes_with_public_key_hex) | add // 0),
      registry_root_bound: (
        length > 0
        and all(.[]; (.registry_root // "") != "")
        and all(.[]; .vote_count == .votes_with_registry_root)
      ),
      compact_votes: (
        length > 0
        and all(.[]; .votes_with_public_key_hex == 0)
      ),
      artifacts: .
    }
    | .ok = (
      .artifact_count > 0
      and .registry_root_bound == true
      and .compact_votes == true
    )' "$tmp" >"$output"
  rm -f "$tmp"
}

require_command jq
require_command date
require_command grep
require_command awk
require_command find
require_command mktemp
require_command wc

require_positive_integer VALIDATORS "$VALIDATORS"
require_positive_integer ROUNDS "$ROUNDS"
require_positive_integer TIMEOUT_SECONDS "$TIMEOUT_SECONDS"
require_positive_integer TRANSPORT_TIMEOUT_MS "$TRANSPORT_TIMEOUT_MS"
case "$WALLET_SIGNER_MODE" in
  node|sdk) ;;
  *)
    echo "WALLET_SIGNER_MODE must be node or sdk" >&2
    exit 2
    ;;
esac
if [ "$VALIDATORS" -lt 2 ]; then
  echo "VALIDATORS must be at least 2 for testnet readiness gate" >&2
  exit 2
fi

rm -rf "$LOG_DIR" "$NODE_DIR"
mkdir -p "$LOG_DIR" "$NODE_DIR" "$(dirname "$REPORT")"

provision_out="$LOG_DIR/provision.out"
PROVISION_OUT_DIR="$LOG_DIR/provision-bundles"
CONFIG_OUT_DIR="$LOG_DIR/config-bundles"
VALIDATORS="$VALIDATORS" \
  OUT_DIR="$PROVISION_OUT_DIR" \
  CONFIG_OUT_DIR="$CONFIG_OUT_DIR" \
  PRIVATE_OUT_DIR="$PROVISION_PRIVATE_OUT_DIR" \
  scripts/testnet-provision-bundle >"$provision_out"
provision_manifest="$(awk -F= '/^manifest=/{print $2}' "$provision_out")"
if [ -z "$provision_manifest" ] || [ ! -f "$provision_manifest" ]; then
  echo "testnet readiness provision step did not emit a manifest" >&2
  cat "$provision_out" >&2
  exit 1
fi
jq -e '.schema == "postfiat-testnet-provision-bundle-v1" and .status == "ready" and .service_defaults.max_connections > 0 and .service_defaults.rpc_child_timeout_ms >= 0 and .service_identity.user == "postfiat" and .service_identity.private_key_mode == "600" and (.systemd_hardening | index("ProtectSystem=strict"))' \
  "$provision_manifest" >/dev/null

remote_deploy_plan_out="$LOG_DIR/remote-deploy-plan.out"
REMOTE_DEPLOY_PLAN_OUT_DIR="$LOG_DIR/remote-deploy-plans"
REMOTE_DEPLOY_CONFIG_OUT_DIR="$LOG_DIR/remote-deploy-config-bundles"
REMOTE_DEPLOY_PROVISION_OUT_DIR="$LOG_DIR/remote-deploy-provision-bundles"
REMOTE_DEPLOY_PRIVATE_OUT_DIR="$ROOT_DIR/remote-deploy-private-key-material"
VALIDATORS="$VALIDATORS" \
  OUT_DIR="$REMOTE_DEPLOY_PLAN_OUT_DIR" \
  CONFIG_OUT_DIR="$REMOTE_DEPLOY_CONFIG_OUT_DIR" \
  PRIVATE_OUT_DIR="$REMOTE_DEPLOY_PRIVATE_OUT_DIR" \
  PROVISION_OUT_DIR="$REMOTE_DEPLOY_PROVISION_OUT_DIR" \
  scripts/testnet-remote-deploy-plan >"$remote_deploy_plan_out"
remote_deploy_plan="$(awk -F= '/^plan=/{print $2}' "$remote_deploy_plan_out")"
if [ -z "$remote_deploy_plan" ] || [ ! -f "$remote_deploy_plan" ]; then
  echo "testnet readiness remote deploy plan step did not emit a plan" >&2
  cat "$remote_deploy_plan_out" >&2
  exit 1
fi
jq -e \
  --argjson validators "$VALIDATORS" \
  '.schema == "postfiat-testnet-remote-deploy-plan-v1" and .status == "ready" and .validators == $validators and (.validator_plan | length) == $validators and .private_key_policy.private_keys_in_public_bundle == false and .private_key_policy.private_keys_in_provision_bundle == false' \
  "$remote_deploy_plan" >/dev/null

