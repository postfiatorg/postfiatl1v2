      $rpc_serve_tamper[0].edge_exhaustion_ok == true
      and $rpc_serve_tamper[0].oversized_request_wave.all_rejected_before_parse == true
      and $rpc_serve_tamper[0].valid_after_tamper_ok == true
    ),
    rpc_serve_matrix_ok: ($rpc_serve_matrix[0].rpc_matrix_ok == true),
