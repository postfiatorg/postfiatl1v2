  and .new_registry_root_verified == true
  and .apply_ok == true
  and .governance_apply_ok == true
  and .duplicate_registry_update_rejected == true
  and .lifecycle_operations_ok == true
  and .live_contiguous_admission.governance_apply_ok == true
  and .live_contiguous_admission.live_registry_root_verified == true
  and .live_key_staging_ok == true
  and .emergency_key_rotation_ok == true
  and .emergency_key_rotation.stale_key_stage_rejected == true
  and .emergency_key_rotation.stale_key_vote_rejected == true
  and .emergency_key_rotation.replacement_key_vote_ok == true
  and .live_non_contiguous_suspend.governance_apply_ok == true
  and .live_non_contiguous_suspend.transfer_apply_ok == true
  and .live_non_contiguous_suspend.signed_proposal_verified == true
  and .live_non_contiguous_suspend.split_certificate_verified == true
  and .live_non_contiguous_suspend.active_validator_list_verified == true
  and .live_non_contiguous_suspend.latest_block_validator_list_verified == true
  and .multi_process_post_suspend.loop_verified == true
  and .multi_process_post_suspend.proposer_rotation_verified == true
  and .multi_process_post_suspend.signed_proposal_verified == true
  and .multi_process_post_suspend.certificate_validator_list_verified == true
