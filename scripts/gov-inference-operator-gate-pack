def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Build a no-spend deterministic governance-agent operator gate pack."
    )
    parser.add_argument("--output", default=str(DEFAULT_OUTPUT), help="output report path")
    parser.add_argument(
        "--model-request",
        default=str(DEFAULT_MODEL_REQUEST),
        help="prompt-facing model request used for validator-evidence lineage audit",
    )
    parser.add_argument(
        "--gate-3_5-report",
        default=str(DEFAULT_GATE_3_5_REPORT),
        help="existing paid replay Gate 3.5 report to verify",
    )
    parser.add_argument(
        "--no-refresh-local",
        action="store_true",
        help="only verify existing reports; do not regenerate local no-spend reports",
    )
    parser.add_argument(
        "--allow-missing-paid-replay",
        action="store_true",
        help="allow missing Gate 3.5 report for local check environments",
    )
    parser.add_argument("--self-test", action="store_true", help="run script self-test")
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    if args.self_test:
        return self_test()
    specs = [dict(spec) for spec in REPORT_SPECS]
    for spec in specs:
        if spec["gate_id"] == "3.5":
            spec["path"] = pathlib.Path(args.gate_3_5_report)
    output = ROOT / args.output
    report = build_pack(
        specs,
        pathlib.Path(args.model_request),
        output,
        refresh_local=not args.no_refresh_local,
        allow_missing_paid_replay=args.allow_missing_paid_replay,
    )
    print(json.dumps(report, indent=2, sort_keys=True))
    return 0 if report["verified"] else 1


if __name__ == "__main__":
    raise SystemExit(main())
