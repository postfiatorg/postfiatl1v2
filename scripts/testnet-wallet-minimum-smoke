#!/usr/bin/env bash
set -euo pipefail

BASE_DIR="${BASE_DIR:-reports/testnet-wallet-minimum-smoke/node}"
LOG_DIR="${LOG_DIR:-reports/testnet-wallet-minimum-smoke/logs}"
PRIVATE_DIR="${PRIVATE_DIR:-reports/testnet-wallet-minimum-smoke/private-wallet-material}"
REPORT="${REPORT:-reports/testnet-wallet-minimum-smoke/testnet-wallet-minimum-smoke-$(date -u +%Y%m%dT%H%M%SZ).json}"
CHAIN_ID="${CHAIN_ID:-postfiat-local}"
MASTER_SEED_HEX="${MASTER_SEED_HEX:-000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f}"
ACCOUNT_INDEX="${ACCOUNT_INDEX:-0}"
FUND_AMOUNT="${FUND_AMOUNT:-70}"
SPEND_AMOUNT="${SPEND_AMOUNT:-15}"
RECIPIENT="${RECIPIENT:-pfwalletrecipient0000000000000000000001}"

require_command() {
  local command="$1"
  if ! command -v "$command" >/dev/null 2>&1; then
    echo "missing required command: $command" >&2
    exit 1
  fi
}

require_nonnegative_integer() {
  local name="$1"
  local value="$2"
  if ! [[ "$value" =~ ^[0-9]+$ ]]; then
    echo "$name must be a nonnegative integer" >&2
    exit 2
  fi
}

require_positive_integer() {
  local name="$1"
  local value="$2"
  if ! [[ "$value" =~ ^[0-9]+$ ]] || [ "$value" -lt 1 ]; then
    echo "$name must be a positive integer" >&2
    exit 2
  fi
}

private_mode() {
  stat -c '%a' "$1"
}

assert_private_mode() {
  local file="$1"
  local mode
  mode="$(private_mode "$file")"
  if [ "$mode" != "600" ]; then
    echo "private wallet file $file has mode $mode, expected 600" >&2
    exit 1
  fi
}

require_command cargo
require_command date
require_command dirname
require_command grep
require_command jq
require_command stat

require_nonnegative_integer ACCOUNT_INDEX "$ACCOUNT_INDEX"
require_positive_integer FUND_AMOUNT "$FUND_AMOUNT"
require_positive_integer SPEND_AMOUNT "$SPEND_AMOUNT"
if [ "$FUND_AMOUNT" -le "$SPEND_AMOUNT" ]; then
  echo "FUND_AMOUNT must exceed SPEND_AMOUNT" >&2
  exit 2
fi

rm -rf "$BASE_DIR" "$LOG_DIR" "$PRIVATE_DIR"
mkdir -p "$BASE_DIR" "$LOG_DIR" "$PRIVATE_DIR" "$(dirname "$REPORT")"

cargo build -p postfiat-node >/dev/null

wallet_key_file="$PRIVATE_DIR/wallet.key.json"
wallet_backup_file="$PRIVATE_DIR/wallet.backup.json"
restored_wallet_key_file="$PRIVATE_DIR/wallet.restored.key.json"
keygen_report="$LOG_DIR/wallet-keygen.json"
restore_report="$LOG_DIR/wallet-restore.json"
fund_batch_file="$LOG_DIR/fund-wallet.batch.json"
fund_receipts_file="$LOG_DIR/fund-wallet.receipts.json"
wallet_account_after_fund_rpc="$LOG_DIR/wallet-account-after-fund.rpc.json"
wallet_spend_batch_file="$LOG_DIR/wallet-spend.batch.json"
wallet_spend_transfer_file="$LOG_DIR/wallet-spend.signed.json"
wallet_spend_submit_file="$LOG_DIR/wallet-spend.submit.json"
mempool_batch_file="$LOG_DIR/wallet-mempool.batch.json"
spend_receipts_file="$LOG_DIR/wallet-spend.receipts.json"
wallet_account_after_spend_rpc="$LOG_DIR/wallet-account-after-spend.rpc.json"
recipient_account_rpc="$LOG_DIR/recipient-account.rpc.json"

target/debug/postfiat-node init \
  --data-dir "$BASE_DIR" \
  --chain-id "$CHAIN_ID" \
  --node-id validator-0 \
  --validators 1 >"$LOG_DIR/init.json"

target/debug/postfiat-node wallet-keygen \
  --chain-id "$CHAIN_ID" \
  --master-seed-hex "$MASTER_SEED_HEX" \
  --account-index "$ACCOUNT_INDEX" \
  --key-file "$wallet_key_file" \
  --backup-file "$wallet_backup_file" >"$keygen_report"

jq -e \
  --arg chain_id "$CHAIN_ID" \
  --argjson account_index "$ACCOUNT_INDEX" \
  '.schema == "postfiat-wallet-key-report-v1"
    and .operation == "keygen"
    and .chain_id == $chain_id
    and .account_index == $account_index
    and .key_role == "transparent-spend"
    and .private_key_material_redacted == true
    and (.address | startswith("pf"))
    and (.public_key_hex | length > 0)' \
  "$keygen_report" >/dev/null
wallet_address="$(jq -r '.address' "$keygen_report")"

assert_private_mode "$wallet_key_file"
assert_private_mode "$wallet_backup_file"

target/debug/postfiat-node wallet-restore \
  --backup-file "$wallet_backup_file" \
  --key-file "$restored_wallet_key_file" >"$restore_report"

jq -e \
  --arg address "$wallet_address" \
  '.schema == "postfiat-wallet-key-report-v1"
    and .operation == "restore"
    and .address == $address
    and .private_key_material_redacted == true' \
  "$restore_report" >/dev/null
jq -n -e \
  --slurpfile original "$wallet_key_file" \
  --slurpfile restored "$restored_wallet_key_file" \
  '$original[0] == $restored[0]' >/dev/null
assert_private_mode "$restored_wallet_key_file"

target/debug/postfiat-node batch-transfer \
  --data-dir "$BASE_DIR" \
  --to "$wallet_address" \
  --amount "$FUND_AMOUNT" \
  --batch-file "$fund_batch_file" >"$LOG_DIR/fund-wallet.batch.out"
target/debug/postfiat-node apply-batch \
  --data-dir "$BASE_DIR" \
  --batch-file "$fund_batch_file" >"$fund_receipts_file"
jq -e 'length == 1 and .[0].accepted == true' "$fund_receipts_file" >/dev/null

target/debug/postfiat-node rpc \
  --data-dir "$BASE_DIR" \
  --method account \
  --address "$wallet_address" \
  --id wallet-after-fund >"$wallet_account_after_fund_rpc"
jq -e \
  --arg address "$wallet_address" \
  --argjson fund_amount "$FUND_AMOUNT" \
  '.ok == true
    and .id == "wallet-after-fund"
    and .result.address == $address
    and .result.balance == $fund_amount
    and .result.sequence == 0
    and .result.public_key_hex == null' \
  "$wallet_account_after_fund_rpc" >/dev/null

target/debug/postfiat-node batch-transfer \
  --data-dir "$BASE_DIR" \
  --key-file "$restored_wallet_key_file" \
  --to "$RECIPIENT" \
  --amount "$SPEND_AMOUNT" \
  --batch-file "$wallet_spend_batch_file" >"$LOG_DIR/wallet-spend.batch.out"
jq -e '.transactions | length == 1' "$wallet_spend_batch_file" >/dev/null
jq '.transactions[0]' "$wallet_spend_batch_file" >"$wallet_spend_transfer_file"

target/debug/postfiat-node mempool-submit-signed-transfer \
  --data-dir "$BASE_DIR" \
  --transfer-file "$wallet_spend_transfer_file" >"$wallet_spend_submit_file"
spend_tx_id="$(jq -r '.tx_id' "$wallet_spend_submit_file")"
if [ -z "$spend_tx_id" ] || [ "$spend_tx_id" = "null" ]; then
  echo "wallet signed transfer submission did not return a tx_id" >&2
  exit 1
fi

target/debug/postfiat-node verify-mempool \
  --data-dir "$BASE_DIR" >"$LOG_DIR/wallet-mempool.verify.json"
jq -e --arg tx_id "$spend_tx_id" \
  '.verified == true and .pending_count == 1 and .latest_tx_id == $tx_id' \
  "$LOG_DIR/wallet-mempool.verify.json" >/dev/null

target/debug/postfiat-node mempool-batch \
  --data-dir "$BASE_DIR" \
  --batch-file "$mempool_batch_file" \
  --max-transactions 1 >"$LOG_DIR/wallet-mempool.batch.out"
target/debug/postfiat-node apply-batch \
  --data-dir "$BASE_DIR" \
  --batch-file "$mempool_batch_file" >"$spend_receipts_file"
jq -e --arg tx_id "$spend_tx_id" \
  'length == 1 and .[0].accepted == true and .[0].tx_id == $tx_id' \
  "$spend_receipts_file" >/dev/null

target/debug/postfiat-node rpc \
  --data-dir "$BASE_DIR" \
  --method account \
  --address "$wallet_address" \
  --id wallet-after-spend >"$wallet_account_after_spend_rpc"
target/debug/postfiat-node rpc \
  --data-dir "$BASE_DIR" \
  --method account \
  --address "$RECIPIENT" \
  --id recipient-after-spend >"$recipient_account_rpc"

jq -e \
  --arg address "$wallet_address" \
  --arg public_key_hex "$(jq -r '.public_key_hex' "$keygen_report")" \
  '.ok == true
    and .id == "wallet-after-spend"
    and .result.address == $address
    and .result.sequence == 1
    and .result.public_key_hex == $public_key_hex
    and .result.balance >= 10' \
  "$wallet_account_after_spend_rpc" >/dev/null
jq -e \
  --arg recipient "$RECIPIENT" \
  --argjson spend_amount "$SPEND_AMOUNT" \
  '.ok == true
    and .id == "recipient-after-spend"
    and .result.address == $recipient
    and .result.balance == $spend_amount' \
  "$recipient_account_rpc" >/dev/null

generated_utc="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
wallet_key_mode="$(private_mode "$wallet_key_file")"
wallet_backup_mode="$(private_mode "$wallet_backup_file")"
restored_wallet_key_mode="$(private_mode "$restored_wallet_key_file")"
jq -n \
  --arg schema "postfiat-testnet-wallet-minimum-smoke-v1" \
  --arg generated_utc "$generated_utc" \
  --arg chain_id "$CHAIN_ID" \
  --arg node_dir "$BASE_DIR" \
  --arg private_dir "$PRIVATE_DIR" \
  --arg wallet_key_file "$wallet_key_file" \
  --arg wallet_backup_file "$wallet_backup_file" \
  --arg restored_wallet_key_file "$restored_wallet_key_file" \
  --arg wallet_address "$wallet_address" \
  --arg recipient "$RECIPIENT" \
  --arg spend_tx_id "$spend_tx_id" \
  --arg wallet_key_mode "$wallet_key_mode" \
  --arg wallet_backup_mode "$wallet_backup_mode" \
  --arg restored_wallet_key_mode "$restored_wallet_key_mode" \
  --argjson account_index "$ACCOUNT_INDEX" \
  --argjson fund_amount "$FUND_AMOUNT" \
  --argjson spend_amount "$SPEND_AMOUNT" \
  --slurpfile keygen "$keygen_report" \
  --slurpfile restore "$restore_report" \
  --slurpfile fund_account "$wallet_account_after_fund_rpc" \
  --slurpfile spend_submit "$wallet_spend_submit_file" \
  --slurpfile mempool_verify "$LOG_DIR/wallet-mempool.verify.json" \
  --slurpfile spend_receipts "$spend_receipts_file" \
  --slurpfile wallet_after_spend "$wallet_account_after_spend_rpc" \
  --slurpfile recipient_after_spend "$recipient_account_rpc" \
  '{
    schema: $schema,
    generated_utc: $generated_utc,
    chain_id: $chain_id,
    node_dir: $node_dir,
    private_dir: $private_dir,
    account_index: $account_index,
    wallet_address: $wallet_address,
    recipient: $recipient,
    fund_amount: $fund_amount,
    spend_amount: $spend_amount,
    spend_tx_id: $spend_tx_id,
    artifacts: {
      wallet_key_file: $wallet_key_file,
      wallet_backup_file: $wallet_backup_file,
      restored_wallet_key_file: $restored_wallet_key_file
    },
    private_file_modes: {
      wallet_key_file: $wallet_key_mode,
      wallet_backup_file: $wallet_backup_mode,
      restored_wallet_key_file: $restored_wallet_key_mode
    },
    keygen_redacted: (
      $keygen[0].private_key_material_redacted == true
      and ($keygen[0] | has("private_key_hex") | not)
      and ($keygen[0] | has("master_seed_hex") | not)
    ),
    deterministic_restore_ok: (
      $restore[0].address == $keygen[0].address
      and $restore[0].public_key_hex == $keygen[0].public_key_hex
      and $restore[0].private_key_material_redacted == true
    ),
    private_file_modes_ok: (
      $wallet_key_mode == "600"
      and $wallet_backup_mode == "600"
      and $restored_wallet_key_mode == "600"
    ),
    rpc_account_query_after_fund_ok: (
      $fund_account[0].ok == true
      and $fund_account[0].result.address == $wallet_address
      and $fund_account[0].result.balance == $fund_amount
      and $fund_account[0].result.sequence == 0
      and $fund_account[0].result.public_key_hex == null
    ),
    signed_transfer_submission_ok: (
      $spend_submit[0].tx_id == $spend_tx_id
      and $mempool_verify[0].verified == true
      and $mempool_verify[0].pending_count == 1
      and $mempool_verify[0].latest_tx_id == $spend_tx_id
    ),
    signed_transfer_apply_ok: (
      ($spend_receipts[0] | length) == 1
      and $spend_receipts[0][0].accepted == true
      and $spend_receipts[0][0].tx_id == $spend_tx_id
    ),
    first_spend_public_key_binding_ok: (
      $wallet_after_spend[0].ok == true
      and $wallet_after_spend[0].result.public_key_hex == $keygen[0].public_key_hex
      and $wallet_after_spend[0].result.sequence == 1
      and $wallet_after_spend[0].result.balance >= 10
    ),
    recipient_credit_ok: (
      $recipient_after_spend[0].ok == true
      and $recipient_after_spend[0].result.address == $recipient
      and $recipient_after_spend[0].result.balance == $spend_amount
    )
  } | .wallet_minimum_ok = (
    .keygen_redacted == true
    and .deterministic_restore_ok == true
    and .private_file_modes_ok == true
    and .rpc_account_query_after_fund_ok == true
    and .signed_transfer_submission_ok == true
    and .signed_transfer_apply_ok == true
    and .first_spend_public_key_binding_ok == true
    and .recipient_credit_ok == true
  )' >"$REPORT"

jq -e \
  '.schema == "postfiat-testnet-wallet-minimum-smoke-v1"
    and .wallet_minimum_ok == true
    and .keygen_redacted == true
    and .deterministic_restore_ok == true
    and .private_file_modes_ok == true
    and .rpc_account_query_after_fund_ok == true
    and .signed_transfer_submission_ok == true
    and .signed_transfer_apply_ok == true
    and .first_spend_public_key_binding_ok == true
    and .recipient_credit_ok == true' \
  "$REPORT" >/dev/null

if grep -R -E '"private_key_hex"|"master_seed_hex"|'"$MASTER_SEED_HEX" "$REPORT" "$LOG_DIR" >/dev/null; then
  echo "wallet minimum smoke leaked private key material into public report or logs" >&2
  exit 1
fi

printf 'testnet_wallet_minimum_smoke=ok report=%s wallet_address=%s tx_id=%s\n' \
  "$REPORT" "$wallet_address" "$spend_tx_id"
