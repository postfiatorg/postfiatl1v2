#!/usr/bin/env python3
"""Prove that the locked Cargo SBOM is byte-identical across checkout paths."""

from __future__ import annotations

import pathlib
import shutil
import subprocess
import tempfile


ROOT = pathlib.Path(__file__).resolve().parents[1]


def main() -> int:
    with tempfile.TemporaryDirectory(prefix="postfiat-sbom-portability-") as raw:
        temporary = pathlib.Path(raw)
        checkout = temporary / "checkout"
        checkout.mkdir()
        tracked = subprocess.check_output(
            ["git", "ls-files", "-z"], cwd=ROOT
        ).split(b"\0")
        for encoded in tracked:
            if not encoded:
                continue
            relative = pathlib.Path(encoded.decode())
            source = ROOT / relative
            destination = checkout / relative
            destination.parent.mkdir(parents=True, exist_ok=True)
            shutil.copy2(source, destination, follow_symlinks=False)

        first = temporary / "first.cdx.json"
        second = temporary / "second.cdx.json"
        subprocess.run([ROOT / "scripts/generate-cargo-sbom", first], check=True)
        subprocess.run(
            [checkout / "scripts/generate-cargo-sbom", second],
            cwd=checkout,
            check=True,
        )
        if first.read_bytes() != second.read_bytes():
            raise RuntimeError("Cargo SBOM differs across checkout paths")
    print("cargo_sbom_portability=ok")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
