#!/usr/bin/env python3
"""Fail-closed secret scan for the tracked tree or every reachable Git diff.

The report deliberately emits only rule, path, and line metadata. It never
prints a candidate value or a reusable digest of that value.
"""

from __future__ import annotations

import argparse
import os
import pathlib
import re
import subprocess
import sys

ROOT = pathlib.Path(
    os.environ.get("POSTFIAT_SECRET_SCAN_ROOT", pathlib.Path(__file__).resolve().parents[1])
).resolve()

RULES = (
    ("private-key-pem", re.compile(rb"-----BEGIN (?:[A-Z0-9 ]+ )?PRIVATE KEY-----")),
    ("aws-access-key", re.compile(rb"\b(?:AKIA|ASIA)[A-Z0-9]{16}\b")),
    ("github-token", re.compile(rb"\bgh(?:p|o|u|s|r)_[A-Za-z0-9]{36,255}\b")),
    ("slack-token", re.compile(rb"\bxox[baprs]-[A-Za-z0-9-]{20,}\b")),
    (
        "jupyter-token",
        re.compile(rb"(?i)jupyter[_-]?token[^\r\n]{0,64}[=:][ \t\"']*[A-Za-z0-9_-]{32,}"),
    ),
    (
        "secret-field",
        re.compile(
            rb"(?i)[\"']?(?:api[_-]?key|access[_-]?token|auth[_-]?token|private_key_hex|secret_key|master_seed_hex|spending_key_hex|mnemonic|passphrase)[\"']?\s*[:=]\s*[\"'][A-Za-z0-9_./+= -]{20,}[\"']"
        ),
    ),
    (
        "private-note-opening",
        re.compile(
            rb"(?i)[\"']?(?:rho|psi|rcm|spend_auth_signing_key)[\"']?\s*:\s*[\"'][0-9a-f]{64,}[\"']"
        ),
    ),
)

# These are exact negative-test or published deterministic-vector locations,
# not generic directory exclusions. A new file or rule still fails closed.
TEST_ONLY_ALLOWLIST = {
    ("secret-field", "crates/node/src/tests/consensus_history.rs"),
    ("secret-field", "crates/node/src/tests/helpers_orchard_transfer_escrow.rs"),
    ("secret-field", "crates/rpc_sdk/src/response_validation_tests.rs"),
    ("secret-field", "crates/node/src/tests/governance_history_manifest_tests.rs"),
    ("secret-field", "scripts/test-navswap-redaction-check.mjs"),
    ("secret-field", "crates/node/src/lib_test_parts/governance_history_manifest_tests.rs"),
    ("secret-field", "crates/node/src/lib_test_parts/helpers_orchard_transfer_escrow.rs"),
    ("secret-field", "crates/rpc_sdk/src/lib_parts/tests_part_02.rs"),
    (
        "secret-field",
        "docs/governance/agent/fixtures/validator_evidence/invalid_private_collector_field.json",
    ),
}

HISTORICAL_TEST_VECTOR_PATHS = {
    "crates/node/src/lib.rs",
    "crates/node/src/lib_tests.rs",
    "crates/rpc_sdk/src/lib.rs",
    "scripts/xrpl-private-control-benchmark",
    "scripts/xrpl-private-control-multihost-benchmark",
}
HISTORICAL_TEST_VECTOR_MARKERS = (
    b"000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f",
    b"000102030405060708090A0B0C0D0E0F101112131415161718191A1B1C1D1E1F",
    b"not allowed in operator manifests",
    b"xrpl-private-control-destination",
)

MAX_TREE_FILE_BYTES = 32 * 1024 * 1024


def tracked_files() -> list[pathlib.Path]:
    raw = subprocess.check_output(["git", "ls-files", "-z"], cwd=ROOT)
    return [ROOT / item.decode("utf-8") for item in raw.split(b"\0") if item]


def scan_line(path: str, line_number: int, line: bytes, findings: list[tuple[str, str, int]]) -> None:
    for rule, pattern in RULES:
        if not pattern.search(line):
            continue
        if (rule, path) in TEST_ONLY_ALLOWLIST:
            continue
        if (
            rule == "secret-field"
            and path in HISTORICAL_TEST_VECTOR_PATHS
            and any(marker in line for marker in HISTORICAL_TEST_VECTOR_MARKERS)
        ):
            continue
        findings.append((rule, path, line_number))


def scan_tree() -> list[tuple[str, str, int]]:
    findings: list[tuple[str, str, int]] = []
    for absolute in tracked_files():
        relative = absolute.relative_to(ROOT).as_posix()
        try:
            size = absolute.stat().st_size
        except FileNotFoundError:
            continue
        if size > MAX_TREE_FILE_BYTES:
            findings.append(("unscannable-large-tracked-file", relative, 0))
            continue
        data = absolute.read_bytes()
        if b"\0" in data[:8192]:
            continue
        for line_number, line in enumerate(data.splitlines(), 1):
            scan_line(relative, line_number, line, findings)
    return findings


def scan_history() -> list[tuple[str, str, int]]:
    findings: list[tuple[str, str, int]] = []
    process = subprocess.Popen(
        ["git", "log", "--all", "--format=commit:%H", "--no-ext-diff", "-p", "--text"],
        cwd=ROOT,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )
    assert process.stdout is not None
    path = "<unknown>"
    added_line = 0
    for raw in process.stdout:
        if raw.startswith(b"+++ b/"):
            path = raw[6:].decode("utf-8", "replace").rstrip("\n")
            continue
        if raw.startswith(b"@@ "):
            match = re.search(rb"\+(\d+)", raw)
            added_line = int(match.group(1)) if match else 0
            continue
        if raw.startswith(b"+") and not raw.startswith(b"+++"):
            scan_line(path, added_line, raw[1:], findings)
            added_line += 1
        elif raw.startswith(b" "):
            added_line += 1
    stderr = process.communicate()[1]
    if process.returncode:
        raise SystemExit(f"git history scan failed: {stderr.decode('utf-8', 'replace')}")
    return findings


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--history", action="store_true", help="scan every reachable Git diff")
    args = parser.parse_args()
    findings = scan_history() if args.history else scan_tree()
    mode = "history" if args.history else "tracked-tree"
    for rule, path, line in findings:
        location = f"{path}:{line}" if line else path
        print(f"SECRET_SCAN finding rule={rule} location={location}", file=sys.stderr)
    if findings:
        print(f"public secret scan FAILED mode={mode} findings={len(findings)}", file=sys.stderr)
        return 1
    print(f"public secret scan passed mode={mode}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
