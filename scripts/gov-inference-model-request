#!/usr/bin/env bash
set -euo pipefail

AGENT_DIR="${AGENT_DIR:-docs/governance/agent}"
REQUEST="${REQUEST:-docs/governance/agent/fixtures/dry_run_model_request.json}"

require_command() {
  local command="$1"
  if ! command -v "$command" >/dev/null 2>&1; then
    echo "missing required command: $command" >&2
    exit 1
  fi
}

require_command cargo
require_command mkdir

cargo build -p postfiat-node >/dev/null

mkdir -p "$(dirname "$REQUEST")"

target/debug/postfiat-node governance-agent-model-request \
  --agent-dir "$AGENT_DIR" \
  --output "$REQUEST" \
  --overwrite
