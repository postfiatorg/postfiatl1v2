#!/usr/bin/env bash
set -euo pipefail

VALIDATORS="${VALIDATORS:-4}"
ROUNDS="${ROUNDS:-3}"
ROOT_DIR="${ROOT_DIR:-reports/testnet-p0-network-gate}"
LOG_DIR="${LOG_DIR:-$ROOT_DIR/logs}"
REPORT="${REPORT:-$ROOT_DIR/testnet-p0-network-gate-$(date -u +%Y%m%dT%H%M%SZ).json}"
TIMEOUT_SECONDS="${TIMEOUT_SECONDS:-20}"
TRANSPORT_TIMEOUT_MS="${TRANSPORT_TIMEOUT_MS:-10000}"
SSH_CRED_FILE="${SSH_CRED_FILE:-$HOME/ssh_cred.txt}"
PLACEMENT_MANIFEST="${PLACEMENT_MANIFEST:-}"
P0_MODE="${P0_MODE:-auto}"
REMOTE_SMOKE_DEPLOY="${REMOTE_SMOKE_DEPLOY:-1}"
REMOTE_TRANSPARENT_DRIVER="${REMOTE_TRANSPARENT_DRIVER:-normal-run}"
P0_REQUIRE_TOPOLOGY_CAPTURE_OK="${P0_REQUIRE_TOPOLOGY_CAPTURE_OK:-0}"
PLACEMENT_REQUIRE_PUBLIC_DIVERSITY="${PLACEMENT_REQUIRE_PUBLIC_DIVERSITY:-0}"
OPEN_FIREWALL="${OPEN_FIREWALL:-0}"
P0_WALLET_SIGNER_MODE="${P0_WALLET_SIGNER_MODE:-sdk}"

require_command() {
  local command="$1"
  if ! command -v "$command" >/dev/null 2>&1; then
    echo "missing required command: $command" >&2
    exit 1
  fi
}

require_positive_integer() {
  local name="$1"
  local value="$2"
  if ! [[ "$value" =~ ^[0-9]+$ ]] || [ "$value" -lt 1 ]; then
    echo "$name must be a positive integer" >&2
    exit 2
  fi
}

newest_report() {
  local dir="$1"
  local pattern="$2"
  find "$dir" -maxdepth 1 -type f -name "$pattern" -printf '%T@ %p\n' \
    | sort -nr \
    | awk 'NR == 1 {print $2}'
}

write_failure_report() {
  local exit_code="$1"
  local generated_utc
  local remote_placement_capacity_summary
  local remote_operator_preflight_summary
  generated_utc="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  remote_placement_capacity_summary="{}"
  remote_operator_preflight_summary="{}"
  if [ -n "${remote_placement_capacity_report:-}" ] && [ -f "$remote_placement_capacity_report" ]; then
    remote_placement_capacity_summary="$(jq -c '{
      placement_capacity_gate_ok: (.placement_capacity_gate_ok // false),
      public_expansion_capacity_gate_ok: (.public_expansion_capacity_gate_ok // false),
      capacity_shortfall: (.capacity_shortfall // {}),
      placement_manifest: {
        present: (.placement_manifest.present // false),
        targets_seen: (.placement_manifest.targets_seen // null),
        bindable_targets: (.placement_manifest.bindable_targets // null),
        complete_controlled_targets: (.placement_manifest.complete_controlled_targets // null),
        complete_public_targets: (.placement_manifest.complete_public_targets // null)
      }
    }' "$remote_placement_capacity_report")"
  fi
  if [ -n "${remote_operator_preflight_report:-}" ] && [ -f "$remote_operator_preflight_report" ]; then
    remote_operator_preflight_summary="$(jq -c '{
      status: (.status // "unknown"),
      operator_preflight_ok: (.operator_preflight_ok // false),
      preflight_only: (.preflight_only // false),
      credential_machine_entries: (.credential_machine_entries // null),
      validators: (.validators // null),
      failed_count: (.operator_preflight_failed_count // null),
      failed_nodes: (.operator_preflight_failed_nodes // []),
      failure_classes: (.operator_preflight_failure_classes // [])
    }' "$remote_operator_preflight_report")"
  fi
  mkdir -p "$(dirname "$REPORT")"
  jq -n \
    --arg schema "postfiat-testnet-p0-network-gate-v1" \
    --arg generated_utc "$generated_utc" \
    --arg mode "$mode" \
    --arg failed_step "$failed_step" \
    --arg remote_blocked_reason "$remote_blocked_reason" \
    --arg remote_placement_capacity_report "$remote_placement_capacity_report" \
    --arg remote_operator_preflight_report "$remote_operator_preflight_report" \
    --arg local_readiness_report "$local_readiness_report" \
    --arg remote_readiness_report "$remote_readiness_report" \
    --arg remote_restart_report "$remote_restart_report" \
    --arg remote_partial_outage_report "$remote_partial_outage_report" \
    --arg remote_rpc_catchup_report "$remote_rpc_catchup_report" \
    --arg remote_validator_registry_report "$remote_validator_registry_report" \
    --arg remote_emergency_key_rotation_report "$remote_emergency_key_rotation_report" \
    --arg remote_topology_capture_profile_report "$remote_topology_capture_profile_report" \
    --arg local_validator_registry_report "$local_validator_registry_report" \
    --arg wallet_test_vectors_report "$wallet_test_vectors_report" \
    --arg wallet_sign_transfer_report "$wallet_sign_transfer_report" \
    --arg wallet_signer_mode "$P0_WALLET_SIGNER_MODE" \
    --arg rpc_write_edge_load_report "$rpc_write_edge_load_report" \
    --arg rpc_read_alias_report "$rpc_read_alias_report" \
    --arg rpc_serve_tamper_report "$rpc_serve_tamper_report" \
    --arg fee_reserve_policy_report "$fee_reserve_policy_report" \
    --arg history_retention_report "$history_retention_report" \
    --arg history_role_policy_report "$history_role_policy_report" \
    --argjson validators "$VALIDATORS" \
    --argjson rounds "$ROUNDS" \
    --argjson exit_code "$exit_code" \
    --argjson remote_blocked "$remote_blocked" \
    --argjson remote_placement_capacity_summary "$remote_placement_capacity_summary" \
    --argjson remote_operator_preflight_summary "$remote_operator_preflight_summary" \
    '{
      schema: $schema,
      generated_utc: $generated_utc,
      status: "failed",
      mode: $mode,
      remote_blocked: $remote_blocked,
      remote_blocked_reason: $remote_blocked_reason,
      validators: $validators,
      rounds: $rounds,
      wallet_signer_mode: $wallet_signer_mode,
      failed_step: $failed_step,
      exit_code: $exit_code,
      reports: {
        remote_placement_capacity_profile: $remote_placement_capacity_report,
        remote_operator_preflight: $remote_operator_preflight_report,
        local_readiness: $local_readiness_report,
        remote_readiness: $remote_readiness_report,
        remote_restart_drill: $remote_restart_report,
        remote_partial_outage_drill: $remote_partial_outage_report,
        remote_rpc_catchup_drill: $remote_rpc_catchup_report,
        remote_validator_registry_drill: $remote_validator_registry_report,
        remote_emergency_key_rotation_rehearsal: $remote_emergency_key_rotation_report,
        remote_topology_capture_profile: $remote_topology_capture_profile_report,
        local_validator_registry_drill: $local_validator_registry_report,
        wallet_test_vectors_smoke: $wallet_test_vectors_report,
        wallet_sign_transfer_smoke: $wallet_sign_transfer_report,
        rpc_serve_tamper: $rpc_serve_tamper_report,
        fee_reserve_policy_smoke: $fee_reserve_policy_report,
        history_retention_smoke: $history_retention_report,
        history_role_policy_smoke: $history_role_policy_report,
        rpc_write_edge_load_smoke: $rpc_write_edge_load_report,
        rpc_read_alias_smoke: $rpc_read_alias_report
      },
      remote_placement_capacity_summary: $remote_placement_capacity_summary,
      remote_operator_preflight_summary: $remote_operator_preflight_summary,
      configured_gate_ok: false,
      p0_network_ok: false
    }' >"$REPORT"
}

require_command jq
require_command date
require_command awk
require_command find
require_command sort
require_command python3

require_positive_integer VALIDATORS "$VALIDATORS"
require_positive_integer ROUNDS "$ROUNDS"
require_positive_integer TIMEOUT_SECONDS "$TIMEOUT_SECONDS"
require_positive_integer TRANSPORT_TIMEOUT_MS "$TRANSPORT_TIMEOUT_MS"
case "$P0_REQUIRE_TOPOLOGY_CAPTURE_OK" in
  0|1) ;;
  *)
    echo "P0_REQUIRE_TOPOLOGY_CAPTURE_OK must be 0 or 1" >&2
    exit 2
    ;;
esac
case "$PLACEMENT_REQUIRE_PUBLIC_DIVERSITY" in
  0|1) ;;
  *)
    echo "PLACEMENT_REQUIRE_PUBLIC_DIVERSITY must be 0 or 1" >&2
    exit 2
    ;;
esac
case "$P0_WALLET_SIGNER_MODE" in
  node|sdk) ;;
  *)
    echo "P0_WALLET_SIGNER_MODE must be node or sdk" >&2
    exit 2
    ;;
esac
if [ "$VALIDATORS" -lt 4 ]; then
  echo "VALIDATORS must be at least 4 for P0 partial-outage/catch-up coverage" >&2
  exit 2
fi

mode=""
remote_blocked=false
remote_blocked_reason=""
case "$P0_MODE" in
  auto)
    if [ -f "$SSH_CRED_FILE" ]; then
      mode="remote"
    else
      mode="local_fallback"
      remote_blocked=true
      remote_blocked_reason="SSH_CRED_FILE missing: $SSH_CRED_FILE"
    fi
    ;;
  remote)
    mode="remote"
    if [ ! -f "$SSH_CRED_FILE" ]; then
      echo "P0_MODE=remote requires SSH_CRED_FILE: $SSH_CRED_FILE" >&2
      exit 2
    fi
    ;;
  local|local_fallback)
    mode="local_fallback"
    remote_blocked=true
    remote_blocked_reason="P0_MODE=$P0_MODE"
    ;;
  *)
    echo "P0_MODE must be auto, remote, local, or local_fallback" >&2
    exit 2
    ;;
esac

if [ -z "$LOG_DIR" ] || [ "$LOG_DIR" = "/" ]; then
  echo "LOG_DIR must not be empty or /" >&2
  exit 2
fi
rm -rf "$LOG_DIR"
mkdir -p "$LOG_DIR" "$(dirname "$REPORT")"

local_root="$LOG_DIR/local-readiness"
local_readiness_report="$local_root/readiness.json"
local_readiness_out="$LOG_DIR/local-readiness.out"
remote_root="$LOG_DIR/remote"
remote_readiness_report="$remote_root/readiness/testnet-remote-readiness-gate.json"
remote_restart_report="$remote_root/restart/testnet-remote-restart-drill.json"
remote_partial_outage_report=""
remote_rpc_catchup_report=""
remote_validator_registry_report=""
remote_emergency_key_rotation_report=""
remote_placement_capacity_report=""
remote_operator_preflight_report=""
remote_topology_capture_profile_report=""
local_validator_registry_report=""
wallet_test_vectors_report=""
wallet_sign_transfer_report=""
rpc_write_edge_load_report=""
rpc_read_alias_report=""
rpc_serve_tamper_report=""
fee_reserve_policy_report=""
transfer_fee_quote_report=""
history_retention_report=""
history_role_policy_report=""
failed_step="initializing"

trap 'rc=$?; if [ "$rc" -ne 0 ]; then write_failure_report "$rc"; fi' EXIT

if [ "$mode" = "remote" ]; then
  failed_step="remote placement capacity profile"
  remote_placement_capacity_report="$LOG_DIR/remote-placement-capacity.json"
  if [ "$P0_REQUIRE_TOPOLOGY_CAPTURE_OK" = "1" ] || [ "$PLACEMENT_REQUIRE_PUBLIC_DIVERSITY" = "1" ]; then
    remote_blocked=true
    remote_blocked_reason="remote placement capacity gate pending: $remote_placement_capacity_report"
  fi
  VALIDATORS="$VALIDATORS" \
    SSH_CRED_FILE="$SSH_CRED_FILE" \
    PLACEMENT_MANIFEST="$PLACEMENT_MANIFEST" \
    PLACEMENT_REQUIRE_STRICT="$P0_REQUIRE_TOPOLOGY_CAPTURE_OK" \
    PLACEMENT_REQUIRE_PUBLIC_DIVERSITY="$PLACEMENT_REQUIRE_PUBLIC_DIVERSITY" \
    REPORT="$remote_placement_capacity_report" \
    scripts/testnet-remote-placement-capacity-profile >"$LOG_DIR/remote-placement-capacity.out"
  jq -e \
    --argjson require_topology_capture_ok "$P0_REQUIRE_TOPOLOGY_CAPTURE_OK" \
    --argjson require_public_diversity "$PLACEMENT_REQUIRE_PUBLIC_DIVERSITY" \
    '.schema == "postfiat-testnet-remote-placement-capacity-profile-v1"
      and .status == "profiled"
      and .placement_capacity_profile_recorded == true
      and (
        if $require_topology_capture_ok == 1 then
          .placement_capacity_gate_ok == true
        else
          true
        end
      )
      and (
        if $require_public_diversity == 1 then
          .public_expansion_capacity_gate_ok == true
        else
          true
        end
      )' \
    "$remote_placement_capacity_report" >/dev/null
  remote_blocked=false
  remote_blocked_reason=""

  failed_step="remote operator preflight"
  remote_operator_preflight_report="$LOG_DIR/remote-operator-preflight.json"
  remote_blocked=true
  remote_blocked_reason="remote operator preflight pending: $remote_operator_preflight_report"
  VALIDATORS="$VALIDATORS" \
    ROUNDS=1 \
    SSH_CRED_FILE="$SSH_CRED_FILE" \
    REMOTE_SMOKE_PREFLIGHT_ONLY=1 \
    REMOTE_SMOKE_BUILD=0 \
    REMOTE_TRANSPARENT_DRIVER="$REMOTE_TRANSPARENT_DRIVER" \
    REPORT="$remote_operator_preflight_report" \
    scripts/testnet-remote-ssh-smoke >"$LOG_DIR/remote-operator-preflight.out"
  jq -e \
    '.schema == "postfiat-testnet-remote-ssh-smoke-v1"
      and .status == "passed"
      and .preflight_only == true
      and .operator_preflight_ok == true' \
    "$remote_operator_preflight_report" >/dev/null
  remote_blocked=false
  remote_blocked_reason=""
fi

failed_step="local readiness gate"
VALIDATORS="$VALIDATORS" \
  ROUNDS="$ROUNDS" \
  ROOT_DIR="$local_root" \
  REPORT="$local_readiness_report" \
  TIMEOUT_SECONDS="$TIMEOUT_SECONDS" \
  TRANSPORT_TIMEOUT_MS="$TRANSPORT_TIMEOUT_MS" \
  WALLET_SIGNER_MODE="$P0_WALLET_SIGNER_MODE" \
  scripts/testnet-readiness-gate >"$local_readiness_out"

jq -e \
  --arg wallet_signer_mode "$P0_WALLET_SIGNER_MODE" \
  '.schema == "postfiat-testnet-readiness-gate-v1"
    and .readiness_ok == true
    and .wallet_signer_mode == $wallet_signer_mode
    and .node_run_peer_certified_ok == true
    and .node_run_peer_certified_restart_ok == true
    and .node_run_peer_certified_partial_outage_ok == true
    and .rpc_catchup_ok == true
    and .rpc_edge_exhaustion_ok == true
    and .wallet_sign_transfer_ok == true
    and .wallet_test_vectors_ok == true
    and .governance_replay_package_ok == true
    and .governance_genesis_bundle_ok == true
    and .rpc_write_edge_load_ok == true
    and .rpc_read_alias_ok == true
    and .history_retention_ok == true
    and .history_role_policy_ok == true' \
  "$local_readiness_report" >/dev/null

provision_manifest="$(jq -r '.reports.provision_manifest' "$local_readiness_report")"
if [ -z "$provision_manifest" ] || [ "$provision_manifest" = "null" ] || [ ! -f "$provision_manifest" ]; then
  echo "local readiness report did not include a usable provision manifest" >&2
  exit 1
fi
local_validator_registry_report="$(jq -r '.reports.validator_registry_update_smoke' "$local_readiness_report")"
if [ -z "$local_validator_registry_report" ] || [ "$local_validator_registry_report" = "null" ] || [ ! -f "$local_validator_registry_report" ]; then
  echo "local readiness report did not include a usable validator registry report" >&2
  exit 1
fi
governance_replay_package_report="$(jq -r '.reports.governance_replay_package_smoke' "$local_readiness_report")"
if [ -z "$governance_replay_package_report" ] || [ "$governance_replay_package_report" = "null" ] || [ ! -f "$governance_replay_package_report" ]; then
  echo "local readiness report did not include a usable governance replay package report" >&2
  exit 1
fi
governance_genesis_bundle_report="$(jq -r '.reports.governance_genesis_bundle_smoke' "$local_readiness_report")"
if [ -z "$governance_genesis_bundle_report" ] || [ "$governance_genesis_bundle_report" = "null" ] || [ ! -f "$governance_genesis_bundle_report" ]; then
  echo "local readiness report did not include a usable governance genesis bundle report" >&2
  exit 1
fi
wallet_test_vectors_report="$(jq -r '.reports.wallet_test_vectors_smoke' "$local_readiness_report")"
if [ -z "$wallet_test_vectors_report" ] || [ "$wallet_test_vectors_report" = "null" ] || [ ! -f "$wallet_test_vectors_report" ]; then
  echo "local readiness report did not include a usable wallet test-vectors report" >&2
  exit 1
fi
wallet_sign_transfer_report="$(jq -r '.reports.wallet_sign_transfer_smoke' "$local_readiness_report")"
if [ -z "$wallet_sign_transfer_report" ] || [ "$wallet_sign_transfer_report" = "null" ] || [ ! -f "$wallet_sign_transfer_report" ]; then
  echo "local readiness report did not include a usable wallet sign-transfer report" >&2
  exit 1
fi
rpc_write_edge_load_report="$(jq -r '.reports.rpc_write_edge_load_smoke' "$local_readiness_report")"
if [ -z "$rpc_write_edge_load_report" ] || [ "$rpc_write_edge_load_report" = "null" ] || [ ! -f "$rpc_write_edge_load_report" ]; then
  echo "local readiness report did not include a usable RPC write-edge load report" >&2
  exit 1
fi
rpc_read_alias_report="$(jq -r '.reports.rpc_read_alias_smoke' "$local_readiness_report")"
if [ -z "$rpc_read_alias_report" ] || [ "$rpc_read_alias_report" = "null" ] || [ ! -f "$rpc_read_alias_report" ]; then
  echo "local readiness report did not include a usable RPC read-alias report" >&2
  exit 1
fi
rpc_serve_tamper_report="$(jq -r '.reports.rpc_serve_tamper' "$local_readiness_report")"
if [ -z "$rpc_serve_tamper_report" ] || [ "$rpc_serve_tamper_report" = "null" ] || [ ! -f "$rpc_serve_tamper_report" ]; then
  echo "local readiness report did not include a usable RPC serve tamper report" >&2
  exit 1
fi
fee_reserve_policy_report="$(jq -r '.reports.fee_reserve_policy_smoke' "$local_readiness_report")"
if [ -z "$fee_reserve_policy_report" ] || [ "$fee_reserve_policy_report" = "null" ] || [ ! -f "$fee_reserve_policy_report" ]; then
  echo "local readiness report did not include a usable fee/reserve policy report" >&2
  exit 1
fi
transfer_fee_quote_report="$(jq -r '.reports.transfer_fee_quote_smoke' "$local_readiness_report")"
if [ -z "$transfer_fee_quote_report" ] || [ "$transfer_fee_quote_report" = "null" ] || [ ! -f "$transfer_fee_quote_report" ]; then
  echo "local readiness report did not include a usable transfer fee quote report" >&2
  exit 1
fi
history_retention_report="$(jq -r '.reports.history_retention_smoke' "$local_readiness_report")"
if [ -z "$history_retention_report" ] || [ "$history_retention_report" = "null" ] || [ ! -f "$history_retention_report" ]; then
  echo "local readiness report did not include a usable history retention report" >&2
  exit 1
fi
history_role_policy_report="$(jq -r '.reports.history_role_policy_smoke' "$local_readiness_report")"
if [ -z "$history_role_policy_report" ] || [ "$history_role_policy_report" = "null" ] || [ ! -f "$history_role_policy_report" ]; then
  echo "local readiness report did not include a usable history role policy report" >&2
  exit 1
fi

if [ "$mode" = "remote" ]; then
  mkdir -p "$remote_root/readiness" "$remote_root/restart" "$remote_root/partial-outage" "$remote_root/rpc-catchup" "$remote_root/validator-registry" "$remote_root/emergency-key-rotation" "$remote_root/topology-capture"

  failed_step="remote readiness gate"
  VALIDATORS="$VALIDATORS" \
    ROUNDS="$ROUNDS" \
    ROOT_DIR="$remote_root/readiness" \
    REPORT="$remote_readiness_report" \
    SSH_CRED_FILE="$SSH_CRED_FILE" \
    OPEN_FIREWALL="$OPEN_FIREWALL" \
    REMOTE_SMOKE_DEPLOY="$REMOTE_SMOKE_DEPLOY" \
    REMOTE_TRANSPARENT_DRIVER="$REMOTE_TRANSPARENT_DRIVER" \
    scripts/testnet-remote-readiness-gate >"$LOG_DIR/remote-readiness.out"

  jq -e \
    '.schema == "postfiat-testnet-remote-readiness-gate-v1"
      and .remote_readiness_ok == true' \
    "$remote_readiness_report" >/dev/null
  remote_plan="$(jq -r '.plan' "$remote_readiness_report")"
  if [ -z "$remote_plan" ] || [ "$remote_plan" = "null" ] || [ ! -f "$remote_plan" ]; then
    echo "remote readiness report did not include a usable plan" >&2
    exit 1
  fi

  failed_step="remote topology capture profile"
  remote_topology_capture_profile_report="$remote_root/topology-capture/testnet-remote-topology-capture-profile.json"
  PLAN="$remote_plan" \
    REPORT_DIR="$remote_root/topology-capture" \
    REPORT="$remote_topology_capture_profile_report" \
    scripts/testnet-remote-topology-capture-profile >"$LOG_DIR/remote-topology-capture.out"
  jq -e \
    '.schema == "postfiat-testnet-remote-topology-capture-profile-v1"
      and .status == "profiled"
      and .topology_capture_profile_recorded == true' \
    "$remote_topology_capture_profile_report" >/dev/null

  failed_step="remote restart drill"
  PLAN="$remote_plan" \
    REPORT_DIR="$remote_root/restart" \
    LOG_DIR="$remote_root/restart/logs" \
    REPORT="$remote_restart_report" \
    SSH_CRED_FILE="$SSH_CRED_FILE" \
    scripts/testnet-remote-restart-drill >"$LOG_DIR/remote-restart.out"
  jq -e \
    '.schema == "postfiat-testnet-remote-restart-drill-v1"
      and .remote_restart_drill_ok == true' \
    "$remote_restart_report" >/dev/null

  failed_step="remote partial-outage drill"
  PLAN="$remote_plan" \
    REPORT_DIR="$remote_root/partial-outage" \
    LOG_DIR="$remote_root/partial-outage/logs" \
    SSH_CRED_FILE="$SSH_CRED_FILE" \
    scripts/testnet-remote-partial-outage-drill >"$LOG_DIR/remote-partial-outage.out"
  remote_partial_outage_report="$(newest_report "$remote_root/partial-outage" 'testnet-remote-partial-outage-drill-*.json')"
  if [ -z "$remote_partial_outage_report" ]; then
    echo "remote partial-outage drill did not emit a report" >&2
    exit 1
  fi
  jq -e \
    '.schema == "postfiat-testnet-remote-partial-outage-drill-v1"
      and .ok == true
      and .final_convergence.all_validators_converged == true' \
    "$remote_partial_outage_report" >/dev/null

  failed_step="remote RPC catch-up drill"
  PLAN="$remote_plan" \
    REPORT_DIR="$remote_root/rpc-catchup" \
    LOG_DIR="$remote_root/rpc-catchup/logs" \
    SSH_CRED_FILE="$SSH_CRED_FILE" \
    scripts/testnet-remote-rpc-catchup-drill >"$LOG_DIR/remote-rpc-catchup.out"
  remote_rpc_catchup_report="$(newest_report "$remote_root/rpc-catchup" 'testnet-remote-rpc-catchup-drill-*.json')"
  if [ -z "$remote_rpc_catchup_report" ]; then
    echo "remote RPC catch-up drill did not emit a report" >&2
    exit 1
  fi
  jq -e \
    '.schema == "postfiat-testnet-remote-rpc-catchup-drill-v1"
      and .ok == true
      and .final_convergence.all_validators_converged == true' \
    "$remote_rpc_catchup_report" >/dev/null

  failed_step="remote validator registry drill"
  PLAN="$remote_plan" \
    REPORT_DIR="$remote_root/validator-registry" \
    LOG_DIR="$remote_root/validator-registry/logs" \
    SSH_CRED_FILE="$SSH_CRED_FILE" \
    scripts/testnet-remote-validator-registry-drill >"$LOG_DIR/remote-validator-registry.out"
  remote_validator_registry_report="$(newest_report "$remote_root/validator-registry" 'testnet-remote-validator-registry-drill-*.json')"
  if [ -z "$remote_validator_registry_report" ]; then
    echo "remote validator registry drill did not emit a report" >&2
    exit 1
  fi
  jq -e \
    '. as $report
      | .schema == "postfiat-testnet-remote-validator-registry-drill-v1"
      and .ok == true
      and .governance_ordering.update_verified == true
      and .governance_ordering.round.certificate_validators == .previous_validators
      and .post_suspend_ordering.round.certificate_validators == .new_validators
      and (.post_suspend_ordering.round.certificate_validators | index($report.subject_node)) == null
      and .post_suspend_ordering.round.local_apply_verified == true
      and .post_suspend_ordering.round.subject_failure_recorded == true
      and .post_suspend_convergence.active_validators_converged == true
      and .active_registry_roots.active_registry_roots_verified == true
      and (
        if .post_suspend_fault_tolerance_required == true then
          .post_suspend_fault_tolerance.verified == true
          and .post_suspend_fault_tolerance.outage_convergence.active_quorum_preserved == true
          and .post_suspend_fault_tolerance.recovery_replay.verified == true
          and .post_suspend_fault_tolerance.final_convergence.active_validators_converged == true
        else
          true
        end
      )' \
    "$remote_validator_registry_report" >/dev/null

  failed_step="remote emergency key-rotation rehearsal"
  remote_emergency_key_rotation_report="$remote_root/emergency-key-rotation/testnet-remote-emergency-key-rotation-rehearsal.json"
  PLAN="$remote_plan" \
    LOCAL_REGISTRY_REPORT="$local_validator_registry_report" \
    REMOTE_REGISTRY_REPORT="$remote_validator_registry_report" \
    REPORT_DIR="$remote_root/emergency-key-rotation" \
    REPORT="$remote_emergency_key_rotation_report" \
    scripts/testnet-remote-emergency-key-rotation-rehearsal >"$LOG_DIR/remote-emergency-key-rotation.out"
  jq -e \
    '.schema == "postfiat-testnet-remote-emergency-key-rotation-rehearsal-v1"
      and .status == "passed"
      and .remote_emergency_key_rotation_rehearsal_ok == true' \
    "$remote_emergency_key_rotation_report" >/dev/null
else
  remote_placement_capacity_report="$LOG_DIR/remote-placement-capacity-skipped.json"
  remote_operator_preflight_report="$LOG_DIR/remote-operator-preflight-skipped.json"
  remote_readiness_report="$LOG_DIR/remote-readiness-skipped.json"
  remote_restart_report="$LOG_DIR/remote-restart-skipped.json"
  remote_partial_outage_report="$LOG_DIR/remote-partial-outage-skipped.json"
  remote_rpc_catchup_report="$LOG_DIR/remote-rpc-catchup-skipped.json"
  remote_validator_registry_report="$LOG_DIR/remote-validator-registry-skipped.json"
  remote_emergency_key_rotation_report="$LOG_DIR/remote-emergency-key-rotation-skipped.json"
  remote_topology_capture_profile_report="$LOG_DIR/remote-topology-capture-skipped.json"
  printf '{}\n' >"$remote_placement_capacity_report"
  printf '{}\n' >"$remote_operator_preflight_report"
  printf '{}\n' >"$remote_readiness_report"
  printf '{}\n' >"$remote_restart_report"
  printf '{}\n' >"$remote_partial_outage_report"
  printf '{}\n' >"$remote_rpc_catchup_report"
  printf '{}\n' >"$remote_validator_registry_report"
  printf '{}\n' >"$remote_emergency_key_rotation_report"
  printf '{}\n' >"$remote_topology_capture_profile_report"
fi

