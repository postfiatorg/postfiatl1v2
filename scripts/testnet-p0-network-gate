      public_redaction_ok: ($governance_genesis_bundle[0].checks.public_redaction_ok == true)
    },
    local_validator_registry_faults: {
      report: $local_validator_registry_report,
      emergency_key_rotation_ok: ($local_registry[0].emergency_key_rotation_ok == true),
      stale_key_stage_rejected: ($local_registry[0].emergency_key_rotation.stale_key_stage_rejected == true),
      stale_key_vote_rejected: ($local_registry[0].emergency_key_rotation.stale_key_vote_rejected == true),
      replacement_key_vote_ok: ($local_registry[0].emergency_key_rotation.replacement_key_vote_ok == true),
      f_plus_one_halt_verified: ($local_registry[0].multi_process_post_suspend.f_plus_one_halt_verified == true),
      f_plus_one_halt_non_skipped: ($local_registry[0].multi_process_post_suspend.f_plus_one_halt.skipped == false),
      f_plus_one_halt_below_quorum: (
        $local_registry[0].multi_process_post_suspend.f_plus_one_halt.halt_threshold_verified == true
        and $local_registry[0].multi_process_post_suspend.f_plus_one_halt.command_failed_below_quorum == true
        and $local_registry[0].multi_process_post_suspend.f_plus_one_halt.no_state_advance == true
      ),
      failed_leader_view_change_verified: ($local_registry[0].multi_process_post_suspend.failed_leader_verified == true),
      failed_leader_view_change_non_skipped: ($local_registry[0].multi_process_post_suspend.failed_leader.skipped == false),
      failed_leader_recovery_ok: (
        $local_registry[0].multi_process_post_suspend.failed_leader.timeout_certificate_verified == true
        and $local_registry[0].multi_process_post_suspend.failed_leader.view_change_round_verified == true
        and $local_registry[0].multi_process_post_suspend.failed_leader.recovery_replay_verified == true
        and $local_registry[0].multi_process_post_suspend.failed_leader.recovered_converged == true
      ),
      partition_verified: ($local_registry[0].multi_process_post_suspend.partition_verified == true),
      partition_non_skipped: ($local_registry[0].multi_process_post_suspend.partition.skipped == false),
      partition_below_quorum: (
        $local_registry[0].multi_process_post_suspend.partition.partition_threshold_verified == true
        and $local_registry[0].multi_process_post_suspend.partition.command_failed_below_quorum == true
        and $local_registry[0].multi_process_post_suspend.partition.certificate_not_written == true
        and $local_registry[0].multi_process_post_suspend.partition.no_state_advance == true
      ),
      stale_vote_verified: ($local_registry[0].multi_process_post_suspend.stale_vote_verified == true),
      stale_vote_non_skipped: ($local_registry[0].multi_process_post_suspend.stale_vote.skipped == false),
      stale_vote_rejected: (
        $local_registry[0].multi_process_post_suspend.stale_vote.stale_vote_rejected == true
        and $local_registry[0].multi_process_post_suspend.stale_vote.certificate_not_written == true
        and $local_registry[0].multi_process_post_suspend.stale_vote.no_state_advance == true
      )
    },
    final_convergence_ok: (
      $local[0].readiness_ok == true
      and $local[0].final_block_height == $rounds
    ),
    private_key_policy_ok: (
      $manifest[0].private_key_policy.included_in_provision_bundle == false
      and (($manifest[0].private_key_policy.private_keys_in_public_bundle // false) == false)
      and $manifest[0].private_key_policy.peer_certified_loop_driver_key_source == "installed_local_validator_key"
      and $manifest[0].private_key_policy.peer_certified_action_loop_driver_key_source == "installed_local_validator_key"
      and $manifest[0].service_identity.private_key_mode == "600"
    ),
    certificate_size_metrics_ok: ($local[0].certificate_size_metrics_ok == true),
    certificate_artifact_metrics: ($local[0].certificate_artifact_metrics // {}),
    remote_readiness_ok: ($remote_readiness[0].remote_readiness_ok == true),
    remote_rpc_edge_load_ok: (
      $remote_readiness[0].remote_rpc_edge_load_ok == true
    ),
    remote_operator_preflight_ok: (
      if $mode != "remote" then
        true
      else
        $remote_operator_preflight[0].schema == "postfiat-testnet-remote-ssh-smoke-v1"
        and $remote_operator_preflight[0].status == "passed"
        and $remote_operator_preflight[0].preflight_only == true
        and $remote_operator_preflight[0].operator_preflight_ok == true
      end
    ),
    remote_operator_preflight_failed_count: (
      $remote_operator_preflight[0].operator_preflight_failed_count // null
    ),
    remote_operator_preflight_failed_nodes: (
      $remote_operator_preflight[0].operator_preflight_failed_nodes // []
    ),
    remote_operator_preflight_failure_classes: (
      $remote_operator_preflight[0].operator_preflight_failure_classes // []
    ),
    remote_restart_recovery_ok: ($remote_restart[0].remote_restart_drill_ok == true),
    remote_partial_outage_quorum_ok: (
      $remote_partial_outage[0].ok == true
      and $remote_partial_outage[0].final_convergence.all_validators_converged == true
    ),
    remote_rpc_catchup_ok: (
      $remote_rpc_catchup[0].ok == true
      and $remote_rpc_catchup[0].final_convergence.all_validators_converged == true
    ),
    remote_validator_registry_update_ok: (
      $remote_validator_registry[0].ok == true
      and $remote_validator_registry[0].governance_ordering.update_verified == true
      and $remote_validator_registry[0].governance_ordering.round.certificate_validators == $remote_validator_registry[0].previous_validators
      and $remote_validator_registry[0].post_suspend_ordering.round.certificate_validators == $remote_validator_registry[0].new_validators
      and ($remote_validator_registry[0].post_suspend_ordering.round.certificate_validators | index($remote_validator_registry[0].subject_node)) == null
      and $remote_validator_registry[0].post_suspend_ordering.round.local_apply_verified == true
      and $remote_validator_registry[0].post_suspend_ordering.round.subject_failure_recorded == true
      and $remote_validator_registry[0].post_suspend_convergence.active_validators_converged == true
      and $remote_validator_registry[0].active_registry_roots.active_registry_roots_verified == true
      and (
        if $remote_validator_registry[0].post_suspend_fault_tolerance_required == true then
          $remote_validator_registry[0].post_suspend_fault_tolerance.verified == true
          and $remote_validator_registry[0].post_suspend_fault_tolerance.outage_convergence.active_quorum_preserved == true
          and $remote_validator_registry[0].post_suspend_fault_tolerance.recovery_replay.verified == true
          and $remote_validator_registry[0].post_suspend_fault_tolerance.final_convergence.active_validators_converged == true
        else
          true
        end
      )
    ),
    remote_validator_registry_fault_tolerance_ok: (
      if $remote_validator_registry[0].post_suspend_fault_tolerance_required == true then
        $remote_validator_registry[0].post_suspend_fault_tolerance.verified == true
        and $remote_validator_registry[0].post_suspend_fault_tolerance.outage_convergence.active_quorum_preserved == true
        and $remote_validator_registry[0].post_suspend_fault_tolerance.recovery_replay.verified == true
        and $remote_validator_registry[0].post_suspend_fault_tolerance.final_convergence.active_validators_converged == true
      else
        $mode != "remote" or $remote_validator_registry[0].ok == true
      end
    ),
    remote_emergency_key_rotation_rehearsal_ok: (
      $remote_emergency_key_rotation[0].schema == "postfiat-testnet-remote-emergency-key-rotation-rehearsal-v1"
      and $remote_emergency_key_rotation[0].status == "passed"
      and $remote_emergency_key_rotation[0].remote_emergency_key_rotation_rehearsal_ok == true
      and $remote_emergency_key_rotation[0].checks.operator_manifest_bound_ok == true
      and $remote_emergency_key_rotation[0].checks.local_emergency_key_rotation_evidence_ok == true
      and $remote_emergency_key_rotation[0].checks.remote_fault_tolerance_evidence_ok == true
    ),
    remote_placement_capacity_profile_recorded: (
      $remote_placement_capacity[0].schema == "postfiat-testnet-remote-placement-capacity-profile-v1"
      and $remote_placement_capacity[0].status == "profiled"
      and $remote_placement_capacity[0].placement_capacity_profile_recorded == true
    ),
    remote_placement_minimum_independent_groups_for_no_blocking: (
      $remote_placement_capacity[0].minimum_independent_groups_for_no_blocking // null
    ),
    remote_placement_complete_machine_entries: (
      $remote_placement_capacity[0].credential_complete_machine_entries // null
    ),
    remote_placement_machine_reuse_required: (
      $remote_placement_capacity[0].machine_reuse_required_for_requested_validators == true
    ),
    remote_placement_manifest_present: (
      $remote_placement_capacity[0].placement_manifest.present == true
    ),
    remote_placement_manifest_bindable_targets: (
      $remote_placement_capacity[0].placement_manifest.bindable_targets // null
    ),
    remote_placement_manifest_complete_controlled_targets: (
      $remote_placement_capacity[0].placement_manifest.complete_controlled_targets // null
    ),
    remote_placement_controlled_missing_independent_groups: (
      $remote_placement_capacity[0].capacity_shortfall.controlled_testnet.max_missing_independent_groups // null
    ),
    remote_placement_public_missing_independent_groups: (
      $remote_placement_capacity[0].capacity_shortfall.public_expansion.max_missing_independent_groups // null
    ),
    remote_placement_shortfall: (
      $remote_placement_capacity[0].capacity_shortfall // {}
    ),
    remote_placement_public_expansion_capacity_gate_ok: (
      if $mode != "remote" then
        true
      elif $require_public_diversity == 1 then
        $remote_placement_capacity[0].public_expansion_capacity_gate_ok == true
      else
        true
      end
    ),
    remote_placement_capacity_gate_ok: (
      if $mode != "remote" then
        true
      elif $require_topology_capture_ok == 1 then
        $remote_placement_capacity[0].placement_capacity_gate_ok == true
      else
        $remote_placement_capacity[0].placement_capacity_profile_recorded == true
      end
    ),
    remote_topology_capture_profile_recorded: (
      $remote_topology_capture_profile[0].schema == "postfiat-testnet-remote-topology-capture-profile-v1"
      and $remote_topology_capture_profile[0].status == "profiled"
      and $remote_topology_capture_profile[0].topology_capture_profile_recorded == true
    ),
    remote_topology_single_group_can_block_quorum: (
      $remote_topology_capture_profile[0].single_group_can_block_quorum == true
    ),
    remote_topology_single_group_can_reach_quorum: (
      $remote_topology_capture_profile[0].single_group_can_reach_quorum == true
    ),
    remote_topology_minimum_groups_to_block_quorum: (
      $remote_topology_capture_profile[0].minimum_groups_to_block_quorum // null
    ),
    remote_topology_minimum_groups_to_reach_quorum: (
      $remote_topology_capture_profile[0].minimum_groups_to_reach_quorum // null
    ),
    remote_topology_capture_threshold_profile_ok: (
      if $mode != "remote" then
        null
      else
        $remote_topology_capture_profile[0].capture_threshold_profile_ok == true
      end
    ),
    remote_topology_capture_thresholds: (
      $remote_topology_capture_profile[0].capture_thresholds // {}
    ),
    remote_topology_capture_profile_ok: (
      $remote_topology_capture_profile[0].topology_capture_profile_ok == true
    ),
    remote_topology_gate_ok: (
      if $mode != "remote" then
        true
      elif $require_topology_capture_ok == 1 then
        $remote_topology_capture_profile[0].topology_capture_profile_ok == true
      else
        $remote_topology_capture_profile[0].topology_capture_profile_recorded == true
      end
    ),
    remote_normal_run_ordering_ok: (
      $mode == "remote"
      and $remote_transparent_driver == "normal-run"
      and $remote_readiness[0].remote_transparent_driver == "normal-run"
      and $remote_readiness[0].remote_normal_run_ordering_ok == true
      and $remote_readiness[0].remote_readiness_ok == true
    )
  } | .remote_drills_ok = (
    if .mode == "remote" then
      .remote_readiness_ok == true
      and .remote_operator_preflight_ok == true
      and .remote_restart_recovery_ok == true
      and .remote_partial_outage_quorum_ok == true
      and .remote_rpc_catchup_ok == true
      and .remote_rpc_edge_load_ok == true
      and .remote_placement_capacity_gate_ok == true
      and .remote_placement_public_expansion_capacity_gate_ok == true
      and .remote_topology_gate_ok == true
      and .remote_validator_registry_update_ok == true
      and .remote_validator_registry_fault_tolerance_ok == true
      and .remote_emergency_key_rotation_rehearsal_ok == true
      and .remote_normal_run_ordering_ok == true
    else
      .remote_blocked == true
    end
  ) | .local_validator_registry_fault_drills_ok = (
    .local_validator_registry_faults.emergency_key_rotation_ok == true
    and .local_validator_registry_faults.stale_key_stage_rejected == true
    and .local_validator_registry_faults.stale_key_vote_rejected == true
    and .local_validator_registry_faults.replacement_key_vote_ok == true
    and .local_validator_registry_faults.f_plus_one_halt_verified == true
    and .local_validator_registry_faults.f_plus_one_halt_non_skipped == true
    and .local_validator_registry_faults.f_plus_one_halt_below_quorum == true
    and .local_validator_registry_faults.failed_leader_view_change_verified == true
    and .local_validator_registry_faults.failed_leader_view_change_non_skipped == true
    and .local_validator_registry_faults.failed_leader_recovery_ok == true
    and .local_validator_registry_faults.partition_verified == true
    and .local_validator_registry_faults.partition_non_skipped == true
    and .local_validator_registry_faults.partition_below_quorum == true
    and .local_validator_registry_faults.stale_vote_verified == true
    and .local_validator_registry_faults.stale_vote_non_skipped == true
    and .local_validator_registry_faults.stale_vote_rejected == true
  ) | .core_p0_checks_ok = (
    .provision_ok == true
    and .normal_rounds_ok == true
    and .restart_recovery_ok == true
    and .partial_outage_quorum_ok == true
    and .rpc_catchup_ok == true
    and .rpc_edge_exhaustion_ok == true
    and .fee_reserve_policy_ok == true
    and .transfer_fee_quote_ok == true
    and .history_retention_ok == true
    and .history_role_policy_ok == true
    and .wallet_minimum_ok == true
    and .wallet_sign_transfer_ok == true
    and .wallet_test_vectors_ok == true
    and .write_edge_load_ok == true
    and .rpc_read_alias_ok == true
    and .validator_registry_update_ok == true
    and .governance_replay_package_ok == true
    and .governance_genesis_bundle_ok == true
    and .local_validator_registry_fault_drills_ok == true
    and .final_convergence_ok == true
    and .private_key_policy_ok == true
    and .certificate_size_metrics_ok == true
  ) | .configured_gate_ok = (
    .core_p0_checks_ok == true
    and .remote_drills_ok == true
  ) | .p0_network_ok = (
    .core_p0_checks_ok == true
    and .mode == "remote"
    and .remote_drills_ok == true
  )' >"$REPORT"

jq -e \
  --arg wallet_signer_mode "$P0_WALLET_SIGNER_MODE" \
  '.schema == "postfiat-testnet-p0-network-gate-v1"
    and .status == "passed"
    and .configured_gate_ok == true
    and .wallet_signer_mode == $wallet_signer_mode
    and .provision_ok == true
    and .normal_rounds_ok == true
    and .restart_recovery_ok == true
    and .partial_outage_quorum_ok == true
    and .rpc_catchup_ok == true
    and .rpc_edge_exhaustion_ok == true
    and .fee_reserve_policy_ok == true
    and .transfer_fee_quote_ok == true
    and .history_retention_ok == true
    and .history_role_policy_ok == true
    and .wallet_minimum_ok == true
    and .wallet_sign_transfer_ok == true
    and .wallet_test_vectors_ok == true
    and .write_edge_load_ok == true
    and .rpc_read_alias_ok == true
    and .validator_registry_update_ok == true
    and .governance_replay_package_ok == true
    and .governance_genesis_bundle_ok == true
    and .local_validator_registry_fault_drills_ok == true
    and .final_convergence_ok == true
    and .private_key_policy_ok == true
    and .certificate_size_metrics_ok == true
    and .remote_validator_registry_fault_tolerance_ok == true
    and (
      .mode != "remote"
      or .remote_rpc_edge_load_ok == true
    )
    and (
      .mode != "remote"
      or .remote_operator_preflight_ok == true
    )
    and (
      .mode != "remote"
      or .remote_placement_capacity_gate_ok == true
    )
    and (
      .mode != "remote"
      or .remote_placement_public_expansion_capacity_gate_ok == true
    )
    and (
      .mode != "remote"
      or .remote_emergency_key_rotation_rehearsal_ok == true
    )
    and (
      .mode != "remote"
      or .remote_topology_gate_ok == true
    )
    and (
      (.mode == "remote" and .p0_network_ok == true)
      or (.mode == "local_fallback" and .remote_blocked == true and .local_fallback_ok == true and .p0_network_ok == false)
    )' \
  "$REPORT" >/dev/null

if grep -R -E '"private_key_hex"|everythingIsRigged|[0-9]{1,3}(\.[0-9]{1,3}){3}' "$REPORT" >/dev/null; then
  echo "P0 network gate report leaked private key, credential, or IP material" >&2
  exit 1
fi

trap - EXIT
printf 'testnet_p0_network_gate=ok mode=%s remote_blocked=%s validators=%s rounds=%s report=%s\n' \
  "$mode" "$remote_blocked" "$VALIDATORS" "$ROUNDS" "$REPORT"
