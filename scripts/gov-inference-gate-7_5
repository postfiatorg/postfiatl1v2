#!/usr/bin/env bash
set -euo pipefail

RULESET="${RULESET:-docs/governance/agent/fixtures/valid_ruleset.json}"
EVIDENCE="${EVIDENCE:-docs/governance/agent/fixtures/frozen_evidence_snapshot.json}"
REPORT="${REPORT:-reports/gov-inference-gate-7_5-ruleset-compiler.json}"

require_command() {
  local command="$1"
  if ! command -v "$command" >/dev/null 2>&1; then
    echo "missing required command: $command" >&2
    exit 1
  fi
}

require_command cargo
require_command mkdir
require_command rm

cargo build -p postfiat-node >/dev/null

mkdir -p "$(dirname "$REPORT")"
rm -f "$REPORT"

target/debug/postfiat-node governance-agent-gate7-5 \
  --ruleset "$RULESET" \
  --evidence "$EVIDENCE" \
  --output "$REPORT" \
  --overwrite
