#!/usr/bin/env bash
set -euo pipefail

AGENT_DIR="${AGENT_DIR:-docs/governance/agent}"
RULESET="${RULESET:-docs/governance/agent/fixtures/valid_ruleset.json}"
EVIDENCE="${EVIDENCE:-docs/governance/agent/fixtures/frozen_evidence_snapshot.json}"
REPORT="${REPORT:-reports/gov-inference-gate-8_5-cobalt-ruleset-dry-run.json}"
REPLAY_BUNDLE="${REPLAY_BUNDLE:-reports/gov-inference-gate-8_5-cobalt-ruleset-dry-run.replay-bundle.json}"

require_command() {
  local command="$1"
  if ! command -v "$command" >/dev/null 2>&1; then
    echo "missing required command: $command" >&2
    exit 1
  fi
}

require_command cargo
require_command mkdir
require_command rm

cargo build -p postfiat-node >/dev/null

mkdir -p "$(dirname "$REPORT")"
mkdir -p "$(dirname "$REPLAY_BUNDLE")"
rm -f "$REPORT" "$REPLAY_BUNDLE"

target/debug/postfiat-node governance-agent-gate8-5 \
  --agent-dir "$AGENT_DIR" \
  --ruleset "$RULESET" \
  --evidence "$EVIDENCE" \
  --output "$REPORT" \
  --replay-bundle-output "$REPLAY_BUNDLE" \
  --overwrite
