#!/usr/bin/env bash
set -euo pipefail

RULESET="${RULESET:-docs/governance/agent/fixtures/valid_ruleset.json}"
COMPARISON_DIR="${COMPARISON_DIR:-docs/governance/agent/fixtures/comparison}"
REPORT="${REPORT:-reports/gov-inference-gate-7_6-ruleset-vs-llm-judgment.json}"

require_command() {
  local command="$1"
  if ! command -v "$command" >/dev/null 2>&1; then
    echo "missing required command: $command" >&2
    exit 1
  fi
}

require_command cargo
require_command mkdir
require_command rm

cargo build -p postfiat-node >/dev/null

mkdir -p "$(dirname "$REPORT")"
rm -f "$REPORT"

target/debug/postfiat-node governance-agent-gate7-6 \
  --ruleset "$RULESET" \
  --comparison-dir "$COMPARISON_DIR" \
  --output "$REPORT" \
  --overwrite
