#!/usr/bin/env python3
import os
import pathlib
import subprocess
import tempfile

repo = pathlib.Path(__file__).resolve().parents[1]
scanner = repo / "scripts" / "public-secret-scan"

with tempfile.TemporaryDirectory(prefix="postfiat-secret-scan-") as raw:
    root = pathlib.Path(raw)
    subprocess.run(["git", "init", "-q"], cwd=root, check=True)
    (root / "clean.txt").write_text("public documentation\n", encoding="utf-8")
    subprocess.run(["git", "add", "clean.txt"], cwd=root, check=True)
    env = {**os.environ, "POSTFIAT_SECRET_SCAN_ROOT": str(root)}
    clean = subprocess.run([scanner], env=env, text=True, capture_output=True)
    assert clean.returncode == 0, clean.stderr

    secret = "a" * 64
    (root / "leak.json").write_text(
        f'{{"jupyter_token":"{secret}"}}\n', encoding="utf-8"
    )
    subprocess.run(["git", "add", "leak.json"], cwd=root, check=True)
    leak = subprocess.run([scanner], env=env, text=True, capture_output=True)
    assert leak.returncode != 0, "known credential shape must fail"
    assert "jupyter-token" in leak.stderr
    assert secret not in leak.stderr, "scanner output must not disclose candidate values"

    # A shielded note opening is spend/privacy material even when it appears in
    # a JSON evidence packet rather than under a conventional key filename.
    # The scanner must fail without echoing the opening value.
    (root / "leak.json").unlink()
    note_opening = "b" * 64
    (root / "orchard-evidence.json").write_text(
        f'{{"note":{{"rho":"{note_opening}","psi":"{note_opening}",'
        f'"rcm":"{note_opening}"}}}}\n',
        encoding="utf-8",
    )
    subprocess.run(["git", "add", "-A"], cwd=root, check=True)
    privacy_leak = subprocess.run([scanner], env=env, text=True, capture_output=True)
    assert privacy_leak.returncode != 0, "shielded note opening must fail"
    assert "private-note-opening" in privacy_leak.stderr
    assert note_opening not in privacy_leak.stderr, "scanner must not disclose note openings"

print("public secret scan regression passed")
