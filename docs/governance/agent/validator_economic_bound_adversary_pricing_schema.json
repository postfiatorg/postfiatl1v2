{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://postfiat.org/schemas/postfiat-validator-economic-bound-adversary-pricing-v1.json",
  "title": "PostFiat Validator Economic-Bound Adversary Pricing",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "packet_id",
    "mode",
    "statement",
    "attestation",
    "checks"
  ],
  "properties": {
    "schema": {
      "const": "postfiat-validator-economic-bound-adversary-pricing-v1"
    },
    "packet_id": {
      "$ref": "#/$defs/id"
    },
    "mode": {
      "const": "controlled_testnet_fixture"
    },
    "statement": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "policy_id",
        "pricing_root_hash",
        "scope",
        "pricing_policy",
        "base_attack",
        "selector_cases",
        "evidence_artifacts"
      ],
      "properties": {
        "policy_id": {
          "$ref": "#/$defs/id"
        },
        "pricing_root_hash": {
          "$ref": "#/$defs/hash96"
        },
        "scope": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "chain_id",
            "profile_id",
            "live_registry_mutation",
            "authority_transfer"
          ]
        },
        "pricing_policy": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "policy_units",
            "max_evidence_age_epochs",
            "route_on_residual_above_budget",
            "route_on_ungoverned_threshold_capture"
          ]
        },
        "base_attack": {
          "type": "object",
          "additionalProperties": true
        },
        "selector_cases": {
          "type": "array",
          "minItems": 10
        },
        "evidence_artifacts": {
          "type": "array",
          "minItems": 1
        }
      }
    },
    "attestation": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "attestor_key_hash",
        "statement_hash",
        "signature_hash",
        "signature_scheme",
        "attested_at"
      ]
    },
    "checks": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]{2,127}$"
    },
    "hash96": {
      "type": "string",
      "pattern": "^[0-9a-f]{96}$"
    }
  }
}
