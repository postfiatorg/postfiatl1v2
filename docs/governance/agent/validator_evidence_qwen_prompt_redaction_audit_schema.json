{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://postfiat.org/schemas/postfiat-validator-evidence-qwen-prompt-redaction-audit-v1.json",
  "title": "PostFiat Validator Evidence Qwen Prompt Redaction Audit",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "audit_id",
    "mode",
    "qwen_prompt_input_manifest_hash",
    "qwen_public_summary_projection_hash",
    "model_request_hash",
    "packet_schema_hash",
    "field_registry_hash",
    "collection_window",
    "scanned_artifacts_order",
    "scanned_artifacts",
    "redaction_summary",
    "execution_boundary",
    "checks"
  ],
  "properties": {
    "schema": {
      "const": "postfiat-validator-evidence-qwen-prompt-redaction-audit-v1"
    },
    "audit_id": {
      "$ref": "#/$defs/id"
    },
    "mode": {
      "const": "design_fixture_only"
    },
    "qwen_prompt_input_manifest_hash": {
      "$ref": "#/$defs/hash96"
    },
    "qwen_public_summary_projection_hash": {
      "$ref": "#/$defs/hash96"
    },
    "model_request_hash": {
      "$ref": "#/$defs/hash96"
    },
    "packet_schema_hash": {
      "$ref": "#/$defs/hash96"
    },
    "field_registry_hash": {
      "$ref": "#/$defs/hash96"
    },
    "collection_window": {
      "$ref": "#/$defs/collection_window"
    },
    "scanned_artifacts_order": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/id"
      }
    },
    "scanned_artifacts": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "patternProperties": {
        "^[a-z0-9][a-z0-9._:-]{2,127}$": {
          "$ref": "#/$defs/scanned_artifact"
        }
      }
    },
    "redaction_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scanned_artifact_count",
        "forbidden_key_hit_count",
        "sensitive_value_hit_count",
        "raw_values_retained",
        "private_fields_removed",
        "secret_scan_passed",
        "public_artifact_safe"
      ],
      "properties": {
        "scanned_artifact_count": {
          "type": "integer",
          "minimum": 1
        },
        "forbidden_key_hit_count": {
          "const": 0
        },
        "sensitive_value_hit_count": {
          "const": 0
        },
        "raw_values_retained": {
          "const": false
        },
        "private_fields_removed": {
          "const": true
        },
        "secret_scan_passed": {
          "const": true
        },
        "public_artifact_safe": {
          "const": true
        }
      }
    },
    "execution_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider_spend_executed",
        "live_model_request_executed",
        "model_output_generated",
        "live_network_access",
        "live_registry_mutation",
        "authority_transfer"
      ],
      "properties": {
        "provider_spend_executed": {
          "const": false
        },
        "live_model_request_executed": {
          "const": false
        },
        "model_output_generated": {
          "const": false
        },
        "live_network_access": {
          "const": false
        },
        "live_registry_mutation": {
          "const": false
        },
        "authority_transfer": {
          "const": false
        }
      }
    },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "qwen_prompt_input_manifest_hash_bound",
        "qwen_public_summary_projection_hash_bound",
        "model_request_hash_bound",
        "packet_schema_hash_bound",
        "field_registry_hash_bound",
        "collection_window_bound",
        "scanned_artifacts_bound",
        "artifact_paths_repo_relative",
        "secret_scan_passed",
        "raw_values_retained",
        "forbidden_key_hits",
        "sensitive_value_hits",
        "provider_spend_executed",
        "live_model_request_executed",
        "model_output_generated",
        "live_network_access",
        "live_registry_mutation",
        "authority_transfer"
      ],
      "properties": {
        "qwen_prompt_input_manifest_hash_bound": {
          "const": true
        },
        "qwen_public_summary_projection_hash_bound": {
          "const": true
        },
        "model_request_hash_bound": {
          "const": true
        },
        "packet_schema_hash_bound": {
          "const": true
        },
        "field_registry_hash_bound": {
          "const": true
        },
        "collection_window_bound": {
          "const": true
        },
        "scanned_artifacts_bound": {
          "const": true
        },
        "artifact_paths_repo_relative": {
          "const": true
        },
        "secret_scan_passed": {
          "const": true
        },
        "raw_values_retained": {
          "const": false
        },
        "forbidden_key_hits": {
          "const": false
        },
        "sensitive_value_hits": {
          "const": false
        },
        "provider_spend_executed": {
          "const": false
        },
        "live_model_request_executed": {
          "const": false
        },
        "model_output_generated": {
          "const": false
        },
        "live_network_access": {
          "const": false
        },
        "live_registry_mutation": {
          "const": false
        },
        "authority_transfer": {
          "const": false
        }
      }
    }
  },
  "$defs": {
    "collection_window": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from_height",
        "to_height",
        "from_time",
        "to_time"
      ],
      "properties": {
        "from_height": {
          "type": "integer",
          "minimum": 0
        },
        "to_height": {
          "type": "integer",
          "minimum": 0
        },
        "from_time": {
          "type": "string",
          "format": "date-time"
        },
        "to_time": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "hash96": {
      "type": "string",
      "pattern": "^[0-9a-f]{96}$"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]{2,127}$"
    },
    "repo_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9_./:-]+$"
    },
    "scanned_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "artifact_kind",
        "path",
        "canonical_sha384",
        "public_artifact_safe",
        "forbidden_key_hits",
        "sensitive_value_hits"
      ],
      "properties": {
        "artifact_id": {
          "$ref": "#/$defs/id"
        },
        "artifact_kind": {
          "enum": [
            "qwen_prompt_input_manifest",
            "qwen_public_summary_projection",
            "dry_run_model_request"
          ],
          "type": "string"
        },
        "path": {
          "$ref": "#/$defs/repo_path"
        },
        "canonical_sha384": {
          "$ref": "#/$defs/hash96"
        },
        "public_artifact_safe": {
          "const": true
        },
        "forbidden_key_hits": {
          "type": "array",
          "maxItems": 0,
          "items": {
            "type": "string"
          }
        },
        "sensitive_value_hits": {
          "type": "array",
          "maxItems": 0,
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
