{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://postfiat.org/schemas/postfiat-validator-evidence-operator-consent-publication-manifest-v1.json",
  "title": "PostFiat Validator Evidence Operator Consent Publication Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "manifest_id",
    "mode",
    "source_authorization_hash",
    "operator_consent_receipt_hash",
    "operator_consent_revocation_index_hash",
    "packet_schema_hash",
    "field_registry_hash",
    "collection_window",
    "publication_scope",
    "summary_entries_order",
    "summary_entries",
    "summary",
    "redaction",
    "checks"
  ],
  "properties": {
    "schema": {
      "const": "postfiat-validator-evidence-operator-consent-publication-manifest-v1"
    },
    "manifest_id": {
      "$ref": "#/$defs/id"
    },
    "mode": {
      "const": "design_fixture_only"
    },
    "source_authorization_hash": {
      "$ref": "#/$defs/hash96"
    },
    "operator_consent_receipt_hash": {
      "$ref": "#/$defs/hash96"
    },
    "operator_consent_revocation_index_hash": {
      "$ref": "#/$defs/hash96"
    },
    "packet_schema_hash": {
      "$ref": "#/$defs/hash96"
    },
    "field_registry_hash": {
      "$ref": "#/$defs/hash96"
    },
    "collection_window": {
      "$ref": "#/$defs/collection_window"
    },
    "publication_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "publication_target",
        "operator_receipt_required",
        "revocation_index_required",
        "qwen_visible_public_summary",
        "raw_values_retained",
        "qwen_raw_access",
        "live_publication_executed"
      ],
      "properties": {
        "publication_target": {
          "const": "design_fixture_public_summary_projection"
        },
        "operator_receipt_required": {
          "const": true
        },
        "revocation_index_required": {
          "const": true
        },
        "qwen_visible_public_summary": {
          "const": true
        },
        "raw_values_retained": {
          "const": false
        },
        "qwen_raw_access": {
          "const": false
        },
        "live_publication_executed": {
          "const": false
        }
      }
    },
    "summary_entries_order": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/id"
      }
    },
    "summary_entries": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "patternProperties": {
        "^[a-z0-9][a-z0-9._:-]{2,127}$": {
          "$ref": "#/$defs/summary_entry"
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary_entry_count",
        "source_count",
        "operator_opt_in_entry_count"
      ],
      "properties": {
        "summary_entry_count": {
          "type": "integer",
          "minimum": 1
        },
        "source_count": {
          "type": "integer",
          "minimum": 1
        },
        "operator_opt_in_entry_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "redaction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_values_retained",
        "private_fields_removed",
        "secret_scan_required",
        "public_artifact_safe"
      ],
      "properties": {
        "raw_values_retained": {
          "const": false
        },
        "private_fields_removed": {
          "const": true
        },
        "secret_scan_required": {
          "const": true
        },
        "public_artifact_safe": {
          "const": true
        }
      }
    },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_authorization_bound",
        "operator_consent_receipt_hash_bound",
        "operator_consent_revocation_index_hash_bound",
        "packet_schema_hash_bound",
        "field_registry_hash_bound",
        "collection_window_bound",
        "receipt_not_revoked",
        "permitted_fields_only",
        "field_paths_registered",
        "raw_values_retained",
        "qwen_raw_access",
        "live_publication_executed",
        "live_registry_mutation",
        "authority_transfer"
      ],
      "properties": {
        "source_authorization_bound": {
          "const": true
        },
        "operator_consent_receipt_hash_bound": {
          "const": true
        },
        "operator_consent_revocation_index_hash_bound": {
          "const": true
        },
        "packet_schema_hash_bound": {
          "const": true
        },
        "field_registry_hash_bound": {
          "const": true
        },
        "collection_window_bound": {
          "const": true
        },
        "receipt_not_revoked": {
          "const": true
        },
        "permitted_fields_only": {
          "const": true
        },
        "field_paths_registered": {
          "const": true
        },
        "raw_values_retained": {
          "const": false
        },
        "qwen_raw_access": {
          "const": false
        },
        "live_publication_executed": {
          "const": false
        },
        "live_registry_mutation": {
          "const": false
        },
        "authority_transfer": {
          "const": false
        }
      }
    }
  },
  "$defs": {
    "collection_window": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from_height",
        "to_height",
        "from_time",
        "to_time"
      ],
      "properties": {
        "from_height": {
          "type": "integer",
          "minimum": 0
        },
        "to_height": {
          "type": "integer",
          "minimum": 0
        },
        "from_time": {
          "type": "string",
          "format": "date-time"
        },
        "to_time": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "hash96": {
      "type": "string",
      "pattern": "^[0-9a-f]{96}$"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]{2,127}$"
    },
    "summary_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_id",
        "source_id",
        "field_path",
        "consent_basis",
        "visibility",
        "summary_value_mode",
        "qwen_visible",
        "raw_value_included",
        "live_value_fetch_authorized",
        "public_artifact_safe"
      ],
      "properties": {
        "entry_id": {
          "$ref": "#/$defs/id"
        },
        "source_id": {
          "$ref": "#/$defs/id"
        },
        "field_path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "consent_basis": {
          "enum": [
            "operator_manifest_signed",
            "operator_opt_in_required"
          ],
          "type": "string"
        },
        "visibility": {
          "enum": [
            "operator_approved_public_summary",
            "collector_observed_public_summary"
          ],
          "type": "string"
        },
        "summary_value_mode": {
          "const": "public_summary_or_hash_only"
        },
        "qwen_visible": {
          "const": true
        },
        "raw_value_included": {
          "const": false
        },
        "live_value_fetch_authorized": {
          "const": false
        },
        "public_artifact_safe": {
          "const": true
        }
      }
    }
  }
}
