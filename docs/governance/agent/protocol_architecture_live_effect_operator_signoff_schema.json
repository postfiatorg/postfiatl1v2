{
  "$id": "https://postfiat.org/schemas/postfiat-protocol-architecture-live-effect-operator-signoff-v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PostFiat Protocol Architecture Live-Effect Operator Signoff",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema": {
      "const": "postfiat-protocol-architecture-live-effect-operator-signoff-v1",
      "type": "string"
    },
    "signoff_id": {
      "$ref": "#/$defs/id"
    },
    "signoff_version": {
      "minimum": 1,
      "type": "integer"
    },
    "status": {
      "const": "operator_signoff_ready_no_execution",
      "type": "string"
    },
    "signoff_scope": {
      "const": "protocol_architecture",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "type": "string"
    },
    "source_rehearsal_ref": {
      "$ref": "#/$defs/source_rehearsal_ref"
    },
    "root_bindings": {
      "$ref": "#/$defs/root_bindings"
    },
    "fresh_root_revalidation": {
      "items": {
        "$ref": "#/$defs/fresh_root_revalidation"
      },
      "minItems": 8,
      "type": "array",
      "uniqueItems": true
    },
    "gate_9_5_review": {
      "$ref": "#/$defs/gate_9_5_review"
    },
    "operator_command_review": {
      "items": {
        "$ref": "#/$defs/operator_command_review"
      },
      "minItems": 5,
      "type": "array",
      "uniqueItems": true
    },
    "signoff_record": {
      "$ref": "#/$defs/signoff_record"
    },
    "execution_authorization_requirement": {
      "$ref": "#/$defs/execution_authorization_requirement"
    },
    "failure_cleanup": {
      "$ref": "#/$defs/failure_cleanup"
    },
    "challenge_path": {
      "$ref": "#/$defs/challenge_path"
    },
    "verification_commands": {
      "items": {
        "$ref": "#/$defs/verification_command"
      },
      "minItems": 7,
      "type": "array",
      "uniqueItems": true
    },
    "authority_boundary": {
      "$ref": "#/$defs/authority_boundary"
    },
    "checks": {
      "$ref": "#/$defs/checks"
    },
    "signoff_root": {
      "$ref": "#/$defs/sha3_384"
    }
  },
  "required": [
    "schema",
    "signoff_id",
    "signoff_version",
    "status",
    "signoff_scope",
    "created_at",
    "source_rehearsal_ref",
    "root_bindings",
    "fresh_root_revalidation",
    "gate_9_5_review",
    "operator_command_review",
    "signoff_record",
    "execution_authorization_requirement",
    "failure_cleanup",
    "challenge_path",
    "verification_commands",
    "authority_boundary",
    "checks",
    "signoff_root"
  ],
  "$defs": {
    "authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider_spend_authorized": {
          "const": false
        },
        "live_model_request_authorized": {
          "const": false
        },
        "model_output_generated_in_this_packet": {
          "const": false
        },
        "operator_signoff_recorded": {
          "const": true
        },
        "operator_signoff_is_execution": {
          "const": false
        },
        "execution_authorization_required_next": {
          "const": true
        },
        "execution_authorized": {
          "const": false
        },
        "release_gate_execution_authorized": {
          "const": false
        },
        "code_rewrite_authorized": {
          "const": false
        },
        "rippled_code_import_authorized": {
          "const": false
        },
        "consensus_rewrite_authorized": {
          "const": false
        },
        "xrpl_compatibility_activation_authorized": {
          "const": false
        },
        "protocol_migration_authorized": {
          "const": false
        },
        "live_validator_registry_mutation_authorized": {
          "const": false
        },
        "live_cobalt_amendment_submission_authorized": {
          "const": false
        },
        "mainnet_mutation_authorized": {
          "const": false
        },
        "authority_transfer_authorized": {
          "const": false
        },
        "default_live_effect_requires_execution_authorization": {
          "const": true
        }
      },
      "required": [
        "provider_spend_authorized",
        "live_model_request_authorized",
        "model_output_generated_in_this_packet",
        "operator_signoff_recorded",
        "operator_signoff_is_execution",
        "execution_authorization_required_next",
        "execution_authorized",
        "release_gate_execution_authorized",
        "code_rewrite_authorized",
        "rippled_code_import_authorized",
        "consensus_rewrite_authorized",
        "xrpl_compatibility_activation_authorized",
        "protocol_migration_authorized",
        "live_validator_registry_mutation_authorized",
        "live_cobalt_amendment_submission_authorized",
        "mainnet_mutation_authorized",
        "authority_transfer_authorized",
        "default_live_effect_requires_execution_authorization"
      ]
    },
    "challenge_path": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "challenge_packet_required": {
          "const": true
        },
        "challenge_schema_path": {
          "const": "docs/governance/agent/constitutional_challenge_packet_schema.json",
          "type": "string"
        },
        "challenge_schema_sha3_384": {
          "$ref": "#/$defs/sha3_384"
        },
        "challenge_action": {
          "const": "hold_signoff_and_require_supersession",
          "type": "string"
        },
        "live_effect": {
          "const": false
        }
      },
      "required": [
        "challenge_packet_required",
        "challenge_schema_path",
        "challenge_schema_sha3_384",
        "challenge_action",
        "live_effect"
      ]
    },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schema_valid": {
          "const": true
        },
        "source_rehearsal_verified": {
          "const": true
        },
        "rehearsal_root_bound": {
          "const": true
        },
        "fresh_roots_verified": {
          "const": true
        },
        "gate_9_5_roots_verified": {
          "const": true
        },
        "operator_commands_reviewed": {
          "const": true
        },
        "stale_root_policy_verified": {
          "const": true
        },
        "challenge_path_verified": {
          "const": true
        },
        "operator_signoff_recorded": {
          "const": true
        },
        "execution_authorization_required_next": {
          "const": true
        },
        "execution_not_authorized": {
          "const": true
        },
        "verification_command_coverage_verified": {
          "const": true
        },
        "no_hidden_evidence": {
          "const": true
        },
        "no_secret_dependency": {
          "const": true
        },
        "no_code_rewrite": {
          "const": true
        },
        "no_live_cobalt_amendment_submission": {
          "const": true
        },
        "no_compatibility_activation": {
          "const": true
        },
        "no_mainnet_mutation": {
          "const": true
        },
        "authority_transfer": {
          "const": false
        },
        "signoff_root_verified": {
          "const": true
        }
      },
      "required": [
        "schema_valid",
        "source_rehearsal_verified",
        "rehearsal_root_bound",
        "fresh_roots_verified",
        "gate_9_5_roots_verified",
        "operator_commands_reviewed",
        "stale_root_policy_verified",
        "challenge_path_verified",
        "operator_signoff_recorded",
        "execution_authorization_required_next",
        "execution_not_authorized",
        "verification_command_coverage_verified",
        "no_hidden_evidence",
        "no_secret_dependency",
        "no_code_rewrite",
        "no_live_cobalt_amendment_submission",
        "no_compatibility_activation",
        "no_mainnet_mutation",
        "authority_transfer",
        "signoff_root_verified"
      ]
    },
    "execution_authorization_requirement": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "execution_authorization_packet_id_required": {
          "const": "vc-protocol-architecture-001-live-effect-execution-authorization-001",
          "type": "string"
        },
        "fresh_root_revalidation_required": {
          "const": true
        },
        "bounded_apply_root_required": {
          "const": true
        },
        "rollback_root_required": {
          "const": true
        },
        "operator_signoff_root_required": {
          "const": true
        },
        "execution_authorized_by_this_packet": {
          "const": false
        },
        "live_effect": {
          "const": false
        }
      },
      "required": [
        "execution_authorization_packet_id_required",
        "fresh_root_revalidation_required",
        "bounded_apply_root_required",
        "rollback_root_required",
        "operator_signoff_root_required",
        "execution_authorized_by_this_packet",
        "live_effect"
      ]
    },
    "failure_cleanup": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "stale_root_action": {
          "const": "hold_signoff_and_require_supersession",
          "type": "string"
        },
        "command_failure_action": {
          "const": "hold_before_execution_authorization",
          "type": "string"
        },
        "rollback_failure_action": {
          "const": "reject_execution_authorization_until_rollback_repaired",
          "type": "string"
        },
        "challenge_action": {
          "const": "hold_signoff_and_require_supersession",
          "type": "string"
        },
        "live_effect": {
          "const": false
        }
      },
      "required": [
        "stale_root_action",
        "command_failure_action",
        "rollback_failure_action",
        "challenge_action",
        "live_effect"
      ]
    },
    "fresh_root_revalidation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "root_id": {
          "$ref": "#/$defs/id"
        },
        "label": {
          "minLength": 3,
          "type": "string"
        },
        "expected_root": {
          "$ref": "#/$defs/hex_hash"
        },
        "observed_root": {
          "$ref": "#/$defs/hex_hash"
        },
        "stale_action": {
          "const": "hold_signoff_and_require_supersession",
          "type": "string"
        },
        "verified": {
          "const": true
        },
        "live_effect": {
          "const": false
        }
      },
      "required": [
        "root_id",
        "label",
        "expected_root",
        "observed_root",
        "stale_action",
        "verified",
        "live_effect"
      ]
    },
    "gate_9_5_review": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source_report_path": {
          "const": "reports/gov-inference-gate-9_5-generated-ruleset-guarded-apply.json",
          "type": "string"
        },
        "source_report_sha3_384": {
          "$ref": "#/$defs/sha3_384"
        },
        "source_report_verified": {
          "const": true
        },
        "candidate_hash": {
          "$ref": "#/$defs/sha3_384"
        },
        "initial_registry_root": {
          "$ref": "#/$defs/sha3_384"
        },
        "post_apply_registry_root": {
          "$ref": "#/$defs/sha3_384"
        },
        "rollback_registry_root": {
          "$ref": "#/$defs/sha3_384"
        },
        "mutation_count": {
          "maximum": 1,
          "minimum": 0,
          "type": "integer"
        },
        "rollback_restored_initial_root": {
          "const": true
        },
        "operator_reviewed": {
          "const": true
        },
        "live_effect": {
          "const": false
        }
      },
      "required": [
        "source_report_path",
        "source_report_sha3_384",
        "source_report_verified",
        "candidate_hash",
        "initial_registry_root",
        "post_apply_registry_root",
        "rollback_registry_root",
        "mutation_count",
        "rollback_restored_initial_root",
        "operator_reviewed",
        "live_effect"
      ]
    },
    "hex_hash": {
      "pattern": "^([0-9a-f]{64}|[0-9a-f]{96})$",
      "type": "string"
    },
    "id": {
      "maxLength": 180,
      "minLength": 8,
      "pattern": "^[a-z0-9][a-z0-9._:-]*$",
      "type": "string"
    },
    "operator_command_review": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "command_id": {
          "$ref": "#/$defs/id"
        },
        "command": {
          "minLength": 3,
          "type": "string"
        },
        "reviewed": {
          "const": true
        },
        "expected_result": {
          "minLength": 3,
          "type": "string"
        },
        "executes_live_action": {
          "const": false
        },
        "live_effect": {
          "const": false
        }
      },
      "required": [
        "command_id",
        "command",
        "reviewed",
        "expected_result",
        "executes_live_action",
        "live_effect"
      ]
    },
    "root_bindings": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rehearsal_root": {
          "$ref": "#/$defs/sha3_384"
        },
        "approval_root": {
          "$ref": "#/$defs/sha3_384"
        },
        "request_root": {
          "$ref": "#/$defs/sha3_384"
        },
        "readiness_root": {
          "$ref": "#/$defs/sha3_384"
        },
        "conformance_review_root": {
          "$ref": "#/$defs/sha3_384"
        },
        "conformance_root": {
          "$ref": "#/$defs/sha3_384"
        },
        "guarded_apply_candidate_hash": {
          "$ref": "#/$defs/sha3_384"
        },
        "guarded_apply_registry_root": {
          "$ref": "#/$defs/sha3_384"
        },
        "rollback_registry_root": {
          "$ref": "#/$defs/sha3_384"
        },
        "full_vocab_vector_root": {
          "$ref": "#/$defs/hex_hash"
        },
        "evidence_packet_root": {
          "$ref": "#/$defs/sha3_384"
        },
        "selected_option": {
          "const": "preserve-rust-l1",
          "type": "string"
        }
      },
      "required": [
        "rehearsal_root",
        "approval_root",
        "request_root",
        "readiness_root",
        "conformance_review_root",
        "conformance_root",
        "guarded_apply_candidate_hash",
        "guarded_apply_registry_root",
        "rollback_registry_root",
        "full_vocab_vector_root",
        "evidence_packet_root",
        "selected_option"
      ]
    },
    "sha3_384": {
      "pattern": "^[0-9a-f]{96}$",
      "type": "string"
    },
    "signoff_record": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "selected_live_action": {
          "const": "protocol_architecture_release_or_cobalt_effect",
          "type": "string"
        },
        "operator_scope": {
          "const": "controlled-testnet-operator-review",
          "type": "string"
        },
        "signoff_status": {
          "const": "ready_for_execution_authorization_packet",
          "type": "string"
        },
        "reviewed_rehearsal_root": {
          "$ref": "#/$defs/sha3_384"
        },
        "reviewed_apply_root": {
          "$ref": "#/$defs/sha3_384"
        },
        "reviewed_rollback_root": {
          "$ref": "#/$defs/sha3_384"
        },
        "signature_material_included": {
          "const": false
        },
        "execution_status": {
          "const": "not_authorized",
          "type": "string"
        },
        "live_effect": {
          "const": false
        },
        "rationale": {
          "minLength": 30,
          "type": "string"
        }
      },
      "required": [
        "selected_live_action",
        "operator_scope",
        "signoff_status",
        "reviewed_rehearsal_root",
        "reviewed_apply_root",
        "reviewed_rollback_root",
        "signature_material_included",
        "execution_status",
        "live_effect",
        "rationale"
      ]
    },
    "source_rehearsal_ref": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rehearsal_id": {
          "const": "vc-protocol-architecture-001-live-effect-guarded-apply-001",
          "type": "string"
        },
        "packet_path": {
          "const": "docs/governance/agent/fixtures/verifiable_constitution/protocol_architecture_live_effect_guarded_apply_rehearsal.json",
          "type": "string"
        },
        "packet_file_sha3_384": {
          "$ref": "#/$defs/sha3_384"
        },
        "packet_canonical_hash": {
          "$ref": "#/$defs/sha3_384"
        },
        "schema_path": {
          "const": "docs/governance/agent/protocol_architecture_live_effect_guarded_apply_rehearsal_schema.json",
          "type": "string"
        },
        "schema_sha3_384": {
          "$ref": "#/$defs/sha3_384"
        },
        "report_path": {
          "const": "reports/verifiable-constitution/vc-061-protocol-architecture-live-effect-guarded-apply-rehearsal-report.json",
          "type": "string"
        },
        "report_file_sha3_384": {
          "$ref": "#/$defs/sha3_384"
        },
        "report_canonical_hash": {
          "$ref": "#/$defs/sha3_384"
        },
        "report_verified": {
          "const": true
        },
        "report_classification": {
          "const": "guarded_apply_rehearsed_no_execution",
          "type": "string"
        },
        "selected_live_action": {
          "const": "protocol_architecture_release_or_cobalt_effect",
          "type": "string"
        },
        "rehearsal_root": {
          "$ref": "#/$defs/sha3_384"
        },
        "report_rehearsal_root": {
          "$ref": "#/$defs/sha3_384"
        }
      },
      "required": [
        "rehearsal_id",
        "packet_path",
        "packet_file_sha3_384",
        "packet_canonical_hash",
        "schema_path",
        "schema_sha3_384",
        "report_path",
        "report_file_sha3_384",
        "report_canonical_hash",
        "report_verified",
        "report_classification",
        "selected_live_action",
        "rehearsal_root",
        "report_rehearsal_root"
      ]
    },
    "verification_command": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "command": {
          "minLength": 3,
          "type": "string"
        },
        "purpose": {
          "minLength": 10,
          "type": "string"
        },
        "expected_result": {
          "const": "pass",
          "type": "string"
        },
        "required": {
          "const": true
        },
        "live_effect": {
          "const": false
        }
      },
      "required": [
        "command",
        "purpose",
        "expected_result",
        "required",
        "live_effect"
      ]
    }
  }
}
