{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://postfiat.org/schemas/postfiat-validator-economic-bound-calibration-v1.json",
  "title": "PostFiat Validator Economic-Bound Calibration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "packet_id",
    "mode",
    "statement",
    "attestation",
    "checks"
  ],
  "properties": {
    "schema": {
      "const": "postfiat-validator-economic-bound-calibration-v1"
    },
    "packet_id": {
      "$ref": "#/$defs/id"
    },
    "mode": {
      "const": "controlled_testnet_fixture"
    },
    "statement": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "policy_id",
        "calibration_root_hash",
        "scope",
        "calibration_policy",
        "base_evidence",
        "selector_cases",
        "evidence_artifacts"
      ],
      "properties": {
        "policy_id": {
          "$ref": "#/$defs/id"
        },
        "calibration_root_hash": {
          "$ref": "#/$defs/hash96"
        },
        "scope": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "chain_id",
            "profile_id",
            "live_registry_mutation",
            "authority_transfer"
          ],
          "properties": {
            "chain_id": {
              "$ref": "#/$defs/id"
            },
            "profile_id": {
              "$ref": "#/$defs/id"
            },
            "live_registry_mutation": {
              "const": false
            },
            "authority_transfer": {
              "const": false
            }
          }
        },
        "calibration_policy": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "policy_units",
            "max_evidence_age_epochs",
            "min_participation_margin_units",
            "min_loss_over_gain_margin_units",
            "term_rules"
          ],
          "properties": {
            "policy_units": {
              "const": "source-measurement-usd-threshold-units-v1"
            },
            "max_evidence_age_epochs": {
              "const": 3
            },
            "min_participation_margin_units": {
              "const": 1
            },
            "min_loss_over_gain_margin_units": {
              "const": 1
            },
            "term_rules": {
              "type": "array",
              "minItems": 6
            }
          }
        },
        "base_evidence": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "source_measurements",
            "cobalt_subset"
          ]
        },
        "selector_cases": {
          "type": "array",
          "minItems": 9
        },
        "evidence_artifacts": {
          "type": "array",
          "minItems": 1
        }
      }
    },
    "attestation": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "attestor_key_hash",
        "statement_hash",
        "signature_hash",
        "signature_scheme",
        "attested_at"
      ]
    },
    "checks": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]{2,127}$"
    },
    "hash96": {
      "type": "string",
      "pattern": "^[0-9a-f]{96}$"
    }
  }
}
