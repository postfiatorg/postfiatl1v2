{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://postfiat.org/schemas/postfiat-validator-economic-synthetic-flow-v1.json",
  "title": "PostFiat Validator Economic Synthetic Flow",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "packet_id",
    "mode",
    "statement",
    "attestation",
    "checks"
  ],
  "properties": {
    "schema": {
      "const": "postfiat-validator-economic-synthetic-flow-v1"
    },
    "packet_id": {
      "$ref": "#/$defs/id"
    },
    "mode": {
      "const": "controlled_testnet_fixture"
    },
    "statement": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "policy_id",
        "synthetic_flow_root_hash",
        "scope",
        "source_policy",
        "candidate",
        "base_evidence",
        "selector_cases",
        "evidence_artifacts"
      ],
      "properties": {
        "policy_id": {
          "$ref": "#/$defs/id"
        },
        "synthetic_flow_root_hash": {
          "$ref": "#/$defs/hash96"
        },
        "scope": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "chain_id",
            "profile_id",
            "live_registry_mutation",
            "authority_transfer"
          ],
          "properties": {
            "chain_id": {
              "$ref": "#/$defs/id"
            },
            "profile_id": {
              "$ref": "#/$defs/id"
            },
            "live_registry_mutation": {
              "const": false
            },
            "authority_transfer": {
              "const": false
            }
          }
        },
        "source_policy": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "policy_units",
            "max_evidence_age_epochs",
            "min_exogenous_benefit_usd",
            "min_distinct_source_control_groups",
            "min_counterparties_per_flow_source",
            "max_roles_per_attestor_group",
            "route_on_affiliated_flow",
            "route_on_stale_or_missing_source",
            "route_on_ungoverned_source_policy"
          ]
        },
        "candidate": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "candidate_id",
            "declared_control_groups"
          ]
        },
        "base_evidence": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "source_policy_governed",
            "candidate_control_groups",
            "exposure_sources"
          ]
        },
        "selector_cases": {
          "type": "array",
          "minItems": 11
        },
        "evidence_artifacts": {
          "type": "array",
          "minItems": 1
        }
      }
    },
    "attestation": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "attestor_key_hash",
        "statement_hash",
        "signature_hash",
        "signature_scheme",
        "attested_at"
      ]
    },
    "checks": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]{2,127}$"
    },
    "hash96": {
      "type": "string",
      "pattern": "^[0-9a-f]{96}$"
    }
  }
}
