{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://postfiat.org/schemas/postfiat-validator-economic-bound-policy-v1.json",
  "title": "PostFiat Validator Economic-Bound Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "packet_id",
    "mode",
    "statement",
    "attestation",
    "checks"
  ],
  "properties": {
    "schema": {
      "const": "postfiat-validator-economic-bound-policy-v1"
    },
    "packet_id": {
      "$ref": "#/$defs/id"
    },
    "mode": {
      "enum": [
        "design_fixture_only",
        "controlled_testnet_attestation"
      ]
    },
    "statement": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "policy_id",
        "policy_root_hash",
        "scope",
        "economic_policy",
        "selector_cases",
        "evidence_artifacts"
      ],
      "properties": {
        "policy_id": {
          "$ref": "#/$defs/id"
        },
        "policy_root_hash": {
          "$ref": "#/$defs/hash96"
        },
        "scope": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "chain_id",
            "profile_id",
            "live_registry_mutation",
            "authority_transfer"
          ],
          "properties": {
            "chain_id": {
              "$ref": "#/$defs/id"
            },
            "profile_id": {
              "$ref": "#/$defs/id"
            },
            "live_registry_mutation": {
              "const": false
            },
            "authority_transfer": {
              "const": false
            }
          }
        },
        "economic_policy": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "policy_units",
            "min_participation_margin_units",
            "min_loss_over_gain_margin_units",
            "max_evidence_age_epochs",
            "cobalt_safe_count_rule",
            "admitted_source_classes"
          ],
          "properties": {
            "policy_units": {
              "const": "ordinal-risk-units-v1"
            },
            "min_participation_margin_units": {
              "const": 1
            },
            "min_loss_over_gain_margin_units": {
              "const": 1
            },
            "max_evidence_age_epochs": {
              "type": "integer",
              "minimum": 1
            },
            "cobalt_safe_count_rule": {
              "const": "safe_count_after > q_s"
            },
            "admitted_source_classes": {
              "type": "array",
              "minItems": 4,
              "uniqueItems": true,
              "items": {
                "enum": [
                  "auditor_attested",
                  "chain_derived",
                  "contract_signed",
                  "counterparty_signed",
                  "operator_signed",
                  "registry_derived"
                ]
              }
            }
          }
        },
        "selector_cases": {
          "type": "array",
          "minItems": 8
        },
        "evidence_artifacts": {
          "type": "array",
          "minItems": 1
        }
      }
    },
    "attestation": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "attestor_key_hash",
        "statement_hash",
        "signature_hash",
        "signature_scheme",
        "attested_at"
      ]
    },
    "checks": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]{2,127}$"
    },
    "hash96": {
      "type": "string",
      "pattern": "^[0-9a-f]{96}$"
    }
  }
}
