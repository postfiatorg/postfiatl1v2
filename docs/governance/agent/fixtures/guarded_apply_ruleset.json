      "action_bound": "no_action",
      "rationale": "The guarded-apply interpreter must preserve registry state whenever evidence, linkedness, concentration, or rollback checks fail."
    },
    {
      "condition": "single_bounded_admit_with_hash_bound_evidence_and_rollback",
      "decision_id": "guarded-apply-one-admit",
