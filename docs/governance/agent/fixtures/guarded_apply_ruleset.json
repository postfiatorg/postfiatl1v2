      "required_provenance": "operator_signed",
      "freshness_requirement": "recent_30d",
      "missing_evidence_behavior": "neutral",
      "conflict_behavior": "hold",
      "action_bound": "admission_gate",
      "rationale": "When frozen evidence, concentration caps, trust graph linkedness, Cobalt acceptance, and rollback evidence all pass, the guarded-apply path may admit exactly one validator."
    }
