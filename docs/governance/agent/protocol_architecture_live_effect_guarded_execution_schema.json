        "challenge_schema_sha3_384": {
          "$ref": "#/$defs/sha3_384"
        },
        "challenge_action": {
          "const": "hold_guarded_execution_and_require_supersession",
          "type": "string"
        },
        "live_effect": {
          "const": false
        }
      },
      "required": [
        "challenge_packet_required",
        "challenge_schema_path",
        "challenge_schema_sha3_384",
        "challenge_action",
        "live_effect"
      ]
