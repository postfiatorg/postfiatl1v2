      "required": [
        "authorization_root",
        "signoff_root",
        "rehearsal_root",
        "approval_root",
        "request_root",
        "readiness_root",
        "conformance_review_root",
        "conformance_root",
        "guarded_apply_candidate_hash",
        "guarded_apply_registry_root",
        "rollback_registry_root",
        "full_vocab_vector_root",
        "evidence_packet_root",
        "selected_option"
      ]
    },
    "sha3_384": {
      "type": "string",
      "pattern": "^[0-9a-f]{96}$"
    },
    "source_authorization_ref": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "authorization_id": {
          "$ref": "#/$defs/id"
