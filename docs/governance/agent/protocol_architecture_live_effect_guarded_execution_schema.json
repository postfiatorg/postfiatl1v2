        "initial_registry_root": {
          "$ref": "#/$defs/sha3_384"
        },
        "post_apply_registry_root": {
          "$ref": "#/$defs/sha3_384"
        },
        "rollback_registry_root": {
          "$ref": "#/$defs/sha3_384"
        },
        "rollback_restores_initial_root": {
          "const": true
        },
        "rollback_required_immediately_before_final_execution": {
          "const": true
