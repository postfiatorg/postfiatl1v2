    "checks": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schema_valid": {
          "const": true
        },
        "source_authorization_verified": {
          "const": true
        },
        "authorization_root_bound": {
          "const": true
        },
        "fresh_roots_verified": {
          "const": true
        },
        "guarded_execution_target_bound": {
          "const": true
        },
        "immediate_preflight_verified": {
          "const": true
        },
        "rollback_drill_verified": {
          "const": true
        },
        "challenge_path_verified": {
          "const": true
        },
        "final_execution_gate_required_next": {
          "const": true
        },
        "final_execution_gate_authorized": {
          "const": true
        },
        "final_execution_not_performed": {
          "const": true
        },
        "verification_command_coverage_verified": {
          "const": true
        },
        "no_hidden_evidence": {
          "const": true
        },
        "no_secret_dependency": {
          "const": true
        },
        "no_code_rewrite": {
          "const": true
        },
        "no_live_cobalt_amendment_submission": {
          "const": true
        },
        "no_compatibility_activation": {
          "const": true
        },
        "no_mainnet_mutation": {
          "const": true
