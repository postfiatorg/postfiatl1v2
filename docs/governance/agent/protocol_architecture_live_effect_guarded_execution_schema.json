{
  "$id": "https://postfiat.org/schemas/postfiat-protocol-architecture-live-effect-guarded-execution-v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PostFiat Protocol Architecture Live-Effect Guarded Execution Packet",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema": {
      "const": "postfiat-protocol-architecture-live-effect-guarded-execution-v1",
      "type": "string"
    },
    "guarded_execution_id": {
      "$ref": "#/$defs/id"
    },
    "guarded_execution_version": {
      "minimum": 1,
      "type": "integer"
    },
    "status": {
      "const": "guarded_execution_ready_no_live_effect",
      "type": "string"
    },
    "execution_scope": {
      "const": "protocol_architecture",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "type": "string"
    },
    "source_authorization_ref": {
      "$ref": "#/$defs/source_authorization_ref"
    },
    "root_bindings": {
      "$ref": "#/$defs/root_bindings"
    },
    "fresh_root_revalidation": {
      "items": {
        "$ref": "#/$defs/fresh_root_revalidation"
      },
      "minItems": 10,
      "type": "array",
      "uniqueItems": true
    },
    "guarded_execution_target": {
      "$ref": "#/$defs/guarded_execution_target"
    },
    "immediate_preflight": {
      "$ref": "#/$defs/immediate_preflight"
    },
    "rollback_drill": {
      "$ref": "#/$defs/rollback_drill"
    },
    "final_execution_gate_requirement": {
      "$ref": "#/$defs/final_execution_gate_requirement"
    },
    "challenge_path": {
      "$ref": "#/$defs/challenge_path"
    },
    "verification_commands": {
      "items": {
        "$ref": "#/$defs/verification_command"
      },
      "minItems": 8,
      "type": "array",
      "uniqueItems": true
    },
    "authority_boundary": {
      "$ref": "#/$defs/authority_boundary"
    },
    "checks": {
      "$ref": "#/$defs/checks"
    },
    "guarded_execution_root": {
      "$ref": "#/$defs/sha3_384"
    }
  },
  "required": [
    "schema",
    "guarded_execution_id",
    "guarded_execution_version",
    "status",
    "execution_scope",
    "created_at",
    "source_authorization_ref",
    "root_bindings",
    "fresh_root_revalidation",
    "guarded_execution_target",
    "immediate_preflight",
    "rollback_drill",
    "final_execution_gate_requirement",
    "challenge_path",
    "verification_commands",
    "authority_boundary",
    "checks",
    "guarded_execution_root"
