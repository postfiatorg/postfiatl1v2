        "request_root": {
          "$ref": "#/$defs/sha3_384"
        },
        "readiness_root": {
          "$ref": "#/$defs/sha3_384"
        },
        "conformance_review_root": {
          "$ref": "#/$defs/sha3_384"
        },
        "conformance_root": {
          "$ref": "#/$defs/sha3_384"
        },
        "guarded_apply_candidate_hash": {
          "$ref": "#/$defs/sha3_384"
        },
        "guarded_apply_registry_root": {
