{
  "$id": "https://postfiat.org/schemas/postfiat-protocol-architecture-live-effect-release-disposition-gate-v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PostFiat Protocol Architecture Live-Effect Release Disposition Gate",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema": {
      "const": "postfiat-protocol-architecture-live-effect-release-disposition-gate-v1",
      "type": "string"
    },
    "release_disposition_id": {
      "const": "vc-protocol-architecture-001-live-effect-release-disposition-001",
      "type": "string"
    },
    "release_disposition_version": {
      "minimum": 1,
      "type": "integer"
    },
    "status": {
      "const": "release_disposition_gate_defined_no_disposition",
      "type": "string"
    },
    "gate_scope": {
      "const": "protocol_architecture",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "type": "string"
    },
    "source_post_action_execution_receipt_gate_ref": {
      "$ref": "#/$defs/source_ref"
    },
    "root_bindings": {
      "$ref": "#/$defs/typed_object"
    },
    "disposition_contract": {
      "$ref": "#/$defs/typed_object"
    },
    "disposition_input_requirements": {
      "$ref": "#/$defs/typed_object"
    },
    "current_disposition_state": {
      "$ref": "#/$defs/typed_object"
    },
    "disposition_matrix": {
      "items": {
        "$ref": "#/$defs/typed_object"
      },
      "minItems": 4,
      "type": "array"
    },
    "rollback_and_challenge_route": {
      "$ref": "#/$defs/typed_object"
    },
    "verification_commands": {
      "items": {
        "$ref": "#/$defs/verification_command"
      },
      "minItems": 1,
      "type": "array"
    },
    "authority_boundary": {
      "$ref": "#/$defs/typed_object"
    },
    "checks": {
      "$ref": "#/$defs/typed_object"
    },
    "release_disposition_root": {
      "$ref": "#/$defs/sha3_384"
    }
  },
  "required": [
    "schema",
    "release_disposition_id",
    "release_disposition_version",
    "status",
    "gate_scope",
    "created_at",
    "source_post_action_execution_receipt_gate_ref",
    "root_bindings",
    "disposition_contract",
    "disposition_input_requirements",
    "current_disposition_state",
    "disposition_matrix",
    "rollback_and_challenge_route",
    "verification_commands",
    "authority_boundary",
    "checks",
    "release_disposition_root"
  ],
  "$defs": {
    "sha3_384": {
      "pattern": "^[0-9a-f]{96}$",
      "type": "string"
    },
    "source_ref": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "fixture_root": {
          "$ref": "#/$defs/sha3_384"
        },
        "report_root": {
          "$ref": "#/$defs/sha3_384"
        },
        "report_verified": {
          "const": true
        },
        "report_classification": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "source_id",
        "fixture_root",
        "report_root",
        "report_verified",
        "report_classification"
      ]
    },
    "typed_object": {
      "type": "object",
      "minProperties": 1
    },
    "verification_command": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "command": {
          "type": "string",
          "minLength": 1
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "expected_result": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "const": true
        },
        "live_effect": {
          "const": false
        }
      },
      "required": [
        "command",
        "purpose",
        "expected_result",
        "required",
        "live_effect"
      ]
    }
  }
}
