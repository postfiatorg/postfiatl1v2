{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://postfiat.org/schemas/postfiat-validator-economic-population-stability-v1.json",
  "title": "PostFiat Validator Economic Population Stability",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "packet_id",
    "mode",
    "statement",
    "attestation",
    "checks"
  ],
  "properties": {
    "schema": {
      "const": "postfiat-validator-economic-population-stability-v1"
    },
    "packet_id": {
      "$ref": "#/$defs/id"
    },
    "mode": {
      "const": "controlled_testnet_fixture"
    },
    "statement": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "policy_id",
        "stability_root_hash",
        "scope",
        "population_policy",
        "base_population",
        "selector_cases",
        "evidence_artifacts"
      ],
      "properties": {
        "policy_id": {
          "$ref": "#/$defs/id"
        },
        "stability_root_hash": {
          "$ref": "#/$defs/hash96"
        },
        "scope": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "chain_id",
            "profile_id",
            "live_registry_mutation",
            "authority_transfer"
          ],
          "properties": {
            "chain_id": {
              "$ref": "#/$defs/id"
            },
            "profile_id": {
              "$ref": "#/$defs/id"
            },
            "live_registry_mutation": {
              "const": false
            },
            "authority_transfer": {
              "const": false
            }
          }
        },
        "population_policy": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "policy_units",
            "n_active",
            "f_tolerated",
            "q_cert",
            "min_bft_safe_count",
            "min_liveness_count",
            "route_on_stale_evidence",
            "route_on_decayed_margin",
            "route_on_bft_margin_eroded",
            "route_on_liveness_margin_eroded",
            "route_on_temporary_offline",
            "route_on_registry_thinning"
          ]
        },
        "base_population": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "n_active",
            "healthy_economic_count",
            "decayed_economic_count",
            "stale_evidence_count",
            "temporary_offline_count",
            "proposed_removal_count",
            "unfilled_slot_count",
            "registry_thinning_delta",
            "population_policy_governed"
          ]
        },
        "selector_cases": {
          "type": "array",
          "minItems": 10
        },
        "evidence_artifacts": {
          "type": "array",
          "minItems": 1
        }
      }
    },
    "attestation": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "attestor_key_hash",
        "statement_hash",
        "signature_hash",
        "signature_scheme",
        "attested_at"
      ]
    },
    "checks": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]{2,127}$"
    },
    "hash96": {
      "type": "string",
      "pattern": "^[0-9a-f]{96}$"
    }
  }
}
