    "immediate_gate_9_5_revalidation": {
      "$ref": "#/$defs/immediate_gate_9_5_revalidation"
    },
    "rollback_availability": {
      "$ref": "#/$defs/rollback_availability"
    },
    "challenge_window": {
      "$ref": "#/$defs/challenge_window"
    },
    "final_command_envelope": {
      "$ref": "#/$defs/final_command_envelope"
    },
    "live_action_packet_requirement": {
      "$ref": "#/$defs/live_action_packet_requirement"
    },
    "verification_commands": {
      "items": {
        "$ref": "#/$defs/verification_command"
      },
      "minItems": 9,
      "type": "array",
      "uniqueItems": true
