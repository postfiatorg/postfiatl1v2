    "schema",
    "final_gate_id",
    "final_gate_version",
    "status",
    "gate_scope",
    "created_at",
    "source_guarded_execution_ref",
    "root_bindings",
    "fresh_root_revalidation",
    "immediate_gate_9_5_revalidation",
    "rollback_availability",
