{
  "$id": "https://postfiat.org/schemas/postfiat-protocol-architecture-live-effect-final-execution-gate-v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PostFiat Protocol Architecture Live-Effect Final Execution Gate",
