    "source_guarded_execution_ref": {
      "$ref": "#/$defs/source_guarded_execution_ref"
    },
    "root_bindings": {
      "$ref": "#/$defs/root_bindings"
    },
    "fresh_root_revalidation": {
      "items": {
        "$ref": "#/$defs/fresh_root_revalidation"
