    "preflight_output_receipt_contract": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "preflight_output_receipt_id_required": {
          "const": "vc-protocol-architecture-001-live-effect-preflight-output-receipt-001",
          "type": "string"
        },
        "exact_authorization_hash_required": {
          "const": true
        },
        "exact_authorization_intake_root_required": {
          "const": true
        },
        "execution_receipt_gate_root_required": {
          "const": true
        },
        "live_action_packet_root_required": {
          "const": true
        },
        "command_stdout_hashes_required": {
          "const": true
        },
        "command_stderr_hashes_required": {
          "const": true
        },
        "command_exit_codes_required": {
          "const": true
        },
        "preflight_output_root_required": {
          "const": true
        },
        "post_authorization_preflight_required": {
          "const": true
        },
        "receipt_not_issued_in_this_packet": {
          "const": true
        },
        "live_effect": {
          "const": false
        }
      },
      "required": [
        "preflight_output_receipt_id_required",
        "exact_authorization_hash_required",
        "exact_authorization_intake_root_required",
        "execution_receipt_gate_root_required",
        "live_action_packet_root_required",
        "command_stdout_hashes_required",
        "command_stderr_hashes_required",
        "command_exit_codes_required",
        "preflight_output_root_required",
        "post_authorization_preflight_required",
        "receipt_not_issued_in_this_packet",
        "live_effect"
      ]
    },
    "root_bindings": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "preflight_output_receipt_gate_id": {
          "const": "vc-protocol-architecture-001-live-effect-preflight-output-receipt-gate-001"
        },
        "preflight_output_receipt_id_required": {
          "const": "vc-protocol-architecture-001-live-effect-preflight-output-receipt-001"
        },
        "exact_authorization_intake_root": {
          "$ref": "#/$defs/sha3_384"
        },
        "exact_authorization_intake_id": {
          "const": "vc-protocol-architecture-001-live-effect-exact-authorization-intake-001"
        },
        "required_authorization_text_sha3_384": {
          "$ref": "#/$defs/sha3_384"
        },
        "execution_receipt_gate_root": {
          "$ref": "#/$defs/sha3_384"
        },
        "execution_receipt_gate_id": {
          "const": "vc-protocol-architecture-001-live-effect-execution-receipt-gate-001"
        },
        "execution_receipt_id_required": {
          "const": "vc-protocol-architecture-001-live-effect-execution-receipt-001"
        },
        "live_action_packet_root": {
          "$ref": "#/$defs/sha3_384"
        },
        "live_action_packet_id": {
          "const": "vc-protocol-architecture-001-live-effect-live-action-001"
        },
        "candidate_live_command_hash": {
          "$ref": "#/$defs/sha3_384"
        },
        "rollback_command_hash": {
          "$ref": "#/$defs/sha3_384"
        },
        "preflight_command_root": {
          "$ref": "#/$defs/sha3_384"
        },
        "selected_live_action": {
          "const": "protocol_architecture_release_or_cobalt_effect"
        },
        "selected_option": {
          "const": "preserve-rust-l1"
        }
