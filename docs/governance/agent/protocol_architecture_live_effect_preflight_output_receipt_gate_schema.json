      "required": [
        "exact_authorization_hash_observed",
        "preflight_executed",
        "preflight_output_receipt_present",
        "preflight_output_receipt_hash",
        "preflight_output_root",
        "command_output_receipts_present",
        "observed_live_effect",
        "live_effect"
