        "stderr_sha3_384_required": {
          "const": true
        },
        "exit_code_required": {
          "const": true
        },
        "current_stdout_sha3_384": {
          "type": "null"
        },
        "current_stderr_sha3_384": {
          "type": "null"
        },
        "current_exit_code": {
          "type": "null"
        },
