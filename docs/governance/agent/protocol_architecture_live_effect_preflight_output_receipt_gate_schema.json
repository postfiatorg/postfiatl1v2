{
  "$id": "https://postfiat.org/schemas/postfiat-protocol-architecture-live-effect-preflight-output-receipt-gate-v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PostFiat Protocol Architecture Live-Effect Preflight Output Receipt Gate",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema": {
      "const": "postfiat-protocol-architecture-live-effect-preflight-output-receipt-gate-v1",
      "type": "string"
    },
    "preflight_output_receipt_gate_id": {
      "const": "vc-protocol-architecture-001-live-effect-preflight-output-receipt-gate-001",
      "type": "string"
    },
    "preflight_output_receipt_gate_version": {
      "minimum": 1,
      "type": "integer"
    },
    "status": {
      "const": "preflight_output_receipt_gate_defined_no_preflight_execution",
      "type": "string"
    },
    "gate_scope": {
      "const": "protocol_architecture",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "type": "string"
    },
    "source_exact_authorization_intake_ref": {
      "$ref": "#/$defs/source_exact_authorization_intake_ref"
    },
    "source_execution_receipt_gate_ref": {
      "$ref": "#/$defs/source_execution_receipt_gate_ref"
    },
    "source_live_action_packet_ref": {
      "$ref": "#/$defs/source_live_action_packet_ref"
    },
    "root_bindings": {
      "$ref": "#/$defs/root_bindings"
    },
    "preflight_output_receipt_contract": {
      "$ref": "#/$defs/preflight_output_receipt_contract"
    },
    "preflight_command_output_requirements": {
      "items": {
        "$ref": "#/$defs/preflight_command_output_requirement"
      },
      "minItems": 5,
      "type": "array",
      "uniqueItems": true
    },
    "current_preflight_state": {
      "$ref": "#/$defs/current_preflight_state"
    },
    "stale_output_rejection_policy": {
      "$ref": "#/$defs/stale_output_rejection_policy"
    },
    "verification_commands": {
      "items": {
        "$ref": "#/$defs/verification_command"
      },
      "minItems": 8,
      "type": "array",
      "uniqueItems": true
    },
    "authority_boundary": {
      "$ref": "#/$defs/authority_boundary"
    },
    "checks": {
      "$ref": "#/$defs/checks"
    },
    "preflight_output_receipt_gate_root": {
      "$ref": "#/$defs/sha3_384"
    }
  },
  "required": [
    "schema",
    "preflight_output_receipt_gate_id",
    "preflight_output_receipt_gate_version",
    "status",
    "gate_scope",
    "created_at",
    "source_exact_authorization_intake_ref",
    "source_execution_receipt_gate_ref",
    "source_live_action_packet_ref",
    "root_bindings",
    "preflight_output_receipt_contract",
    "preflight_command_output_requirements",
    "current_preflight_state",
    "stale_output_rejection_policy",
    "verification_commands",
    "authority_boundary",
    "checks",
    "preflight_output_receipt_gate_root"
