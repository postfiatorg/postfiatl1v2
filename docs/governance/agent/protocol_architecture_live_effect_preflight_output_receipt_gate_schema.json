    "checks": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schema_valid": {
          "const": true
        },
        "source_exact_authorization_intake_verified": {
          "const": true
        },
        "source_execution_receipt_gate_verified": {
          "const": true
        },
        "source_live_action_packet_verified": {
          "const": true
        },
        "root_bindings_verified": {
          "const": true
        },
        "preflight_output_receipt_contract_verified": {
          "const": true
        },
        "preflight_command_output_requirements_verified": {
          "const": true
        },
        "current_preflight_state_verified": {
          "const": true
        },
        "stale_output_rejection_policy_verified": {
          "const": true
        },
        "verification_command_coverage_verified": {
          "const": true
        },
        "closed_authority_boundary_verified": {
          "const": true
        },
        "no_hidden_evidence": {
          "const": true
        },
        "no_secret_dependency": {
          "const": true
        },
        "no_preflight_execution": {
          "const": true
        },
        "no_preflight_output_receipt_issued": {
          "const": true
        },
        "no_live_action_execution": {
          "const": true
        },
        "no_live_cobalt_amendment_submission": {
          "const": true
        },
        "no_compatibility_activation": {
          "const": true
        },
        "no_mainnet_mutation": {
          "const": true
        },
        "authority_transfer": {
          "const": false
        },
        "preflight_output_receipt_gate_root_verified": {
          "const": true
        }
      },
      "required": [
        "schema_valid",
        "source_exact_authorization_intake_verified",
        "source_execution_receipt_gate_verified",
        "source_live_action_packet_verified",
        "root_bindings_verified",
        "preflight_output_receipt_contract_verified",
        "preflight_command_output_requirements_verified",
        "current_preflight_state_verified",
        "stale_output_rejection_policy_verified",
        "verification_command_coverage_verified",
        "closed_authority_boundary_verified",
        "no_hidden_evidence",
        "no_secret_dependency",
        "no_preflight_execution",
        "no_preflight_output_receipt_issued",
        "no_live_action_execution",
        "no_live_cobalt_amendment_submission",
        "no_compatibility_activation",
        "no_mainnet_mutation",
        "authority_transfer",
        "preflight_output_receipt_gate_root_verified"
