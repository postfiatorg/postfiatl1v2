      "type": "object",
      "additionalProperties": false,
      "properties": {
        "exact_authorization_hash_observed": {
          "type": "null"
        },
        "preflight_executed": {
          "const": false
        },
        "preflight_output_receipt_present": {
          "const": false
        },
        "preflight_output_receipt_hash": {
          "type": "null"
