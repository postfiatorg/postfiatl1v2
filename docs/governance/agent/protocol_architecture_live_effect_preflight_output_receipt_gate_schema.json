      "type": "object",
      "additionalProperties": false,
      "properties": {
        "exact_authorization_intake_id": {
          "$ref": "#/$defs/id"
        },
        "fixture_path": {
          "type": "string",
          "minLength": 1
        },
        "fixture_file_sha3_384": {
          "$ref": "#/$defs/sha3_384"
        },
        "fixture_canonical_hash": {
          "$ref": "#/$defs/sha3_384"
        },
        "schema_path": {
          "type": "string",
          "minLength": 1
        },
        "schema_sha3_384": {
          "$ref": "#/$defs/sha3_384"
        },
        "report_path": {
          "type": "string",
          "minLength": 1
        },
        "report_file_sha3_384": {
          "$ref": "#/$defs/sha3_384"
        },
        "report_canonical_hash": {
          "$ref": "#/$defs/sha3_384"
        },
        "report_verified": {
          "const": true
        },
        "report_classification": {
          "const": "exact_authorization_intake_defined_no_authorization",
          "type": "string"
        },
        "exact_authorization_intake_root": {
          "$ref": "#/$defs/sha3_384"
        },
        "report_exact_authorization_intake_root": {
          "$ref": "#/$defs/sha3_384"
        }
      },
      "required": [
        "exact_authorization_intake_id",
        "fixture_path",
        "fixture_file_sha3_384",
        "fixture_canonical_hash",
        "schema_path",
        "schema_sha3_384",
        "report_path",
        "report_file_sha3_384",
        "report_canonical_hash",
        "report_verified",
        "report_classification",
        "exact_authorization_intake_root",
        "report_exact_authorization_intake_root"
      ]
    },
    "source_execution_receipt_gate_ref": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "execution_receipt_gate_id": {
          "$ref": "#/$defs/id"
        },
        "execution_receipt_gate_root": {
          "$ref": "#/$defs/sha3_384"
        },
        "report_verified": {
          "const": true
        },
        "report_classification": {
          "const": "execution_receipt_gate_defined_no_execution",
          "type": "string"
        }
      },
      "required": [
        "execution_receipt_gate_id",
        "execution_receipt_gate_root",
        "report_verified",
        "report_classification"
      ]
    },
    "source_live_action_packet_ref": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "live_action_packet_id": {
          "$ref": "#/$defs/id"
        },
        "live_action_packet_root": {
          "$ref": "#/$defs/sha3_384"
        },
        "report_verified": {
          "const": true
        },
        "report_classification": {
          "const": "explicit_live_action_packet_bound_no_execution",
          "type": "string"
        }
      },
      "required": [
        "live_action_packet_id",
        "live_action_packet_root",
        "report_verified",
        "report_classification"
      ]
    },
    "stale_output_rejection_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "preflight_must_run_after_exact_authorization": {
          "const": true
        },
        "authorization_hash_must_match_root_binding": {
          "const": true
        },
        "preflight_command_root_must_match_root_binding": {
          "const": true
        },
        "stale_authorization_rejected": {
          "const": true
        },
        "stale_preflight_output_rejected": {
          "const": true
        },
        "missing_stdout_hash_rejected": {
          "const": true
        },
        "missing_stderr_hash_rejected": {
          "const": true
        },
        "missing_exit_code_rejected": {
          "const": true
        },
        "unexpected_live_effect_failure_action": {
          "const": "hold_preflight_output_receipt_and_require_challenge_or_rollback",
          "type": "string"
        },
        "live_effect": {
          "const": false
        }
      },
      "required": [
        "preflight_must_run_after_exact_authorization",
        "authorization_hash_must_match_root_binding",
        "preflight_command_root_must_match_root_binding",
        "stale_authorization_rejected",
        "stale_preflight_output_rejected",
        "missing_stdout_hash_rejected",
        "missing_stderr_hash_rejected",
        "missing_exit_code_rejected",
        "unexpected_live_effect_failure_action",
